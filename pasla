def _build_serve_parser() -> argparse.ArgumentParser:
    """Parser for the default serve-a-file mode."""
    p = argparse.ArgumentParser(
        prog="pasla",
        description="Secure ephemeral file-sharing server.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    p.add_argument("file",          help="File to share.")
    p.add_argument("duration",      nargs="?", type=int, default=60,
                   help="Expiry duration in minutes (default: 60).")
    p.add_argument("max_downloads", nargs="?", type=int, default=0,
                   help="Maximum downloads; 0 = unlimited (default: 0).")
    p.add_argument("-d", "--detach", action="store_true",
                   help="Run server in background and print the URL, then exit.")
    p.add_argument("-v", "--version", action="version",
                   version=f"pasla {__version__}",
                   help="Show the pasla version and exit.")
    ip_group = p.add_mutually_exclusive_group()
    ip_group.add_argument("-4", "--ipv4", action="store_const", const="4",
                          dest="ip_mode", help="Show only IPv4 URL.")
    ip_group.add_argument("-6", "--ipv6", action="store_const", const="6",
                          dest="ip_mode", help="Show only IPv6 URL.")
    p.set_defaults(ip_mode=None)  # None = both
    p.add_argument("--trust-proxy", action="store_true", dest="trust_proxy",
                   help=(
                       "Read client IP from X-Forwarded-For. "
                       "Use only behind a trusted reverse proxy."
                   ))
    p.add_argument("--trust-header", dest="trust_header", default=None,
                   help=(
                       "When --trust-proxy is active, read client IP from this "
                       "specific header instead of X-Forwarded-For.  Known "
                       "headers: " + ", ".join(TRUSTED_CLIENT_IP_HEADERS) + ".  "
                       "Requires --trust-proxy."
                   ))
    p.add_argument("-p", "--port", type=int, default=None,
                   help="Port to bind to (default: random %d-%d)." % (
                       PORT_RANGE_START, PORT_RANGE_END,
                   ))
    p.add_argument("--single", action="store_true",
                   help="Equivalent to max_downloads=1 (single-use link).")
    p.add_argument("--json", action="store_true", dest="json_output",
                   help="Print machine-readable JSON to stdout, suppress TUI.")
    p.add_argument("--allow-ip", action="append", default=None,
                   dest="allow_cidrs",
                   help="Restrict downloads to these IP/CIDR ranges. Repeatable.")
    https_group = p.add_mutually_exclusive_group()
    https_group.add_argument(
        "--https", action="store_true", default=False,
        help="Enable TLS.  Without --tls-cert/--tls-key, an ephemeral "
             "self-signed certificate is generated (requires openssl on "
             "PATH).  Implied automatically when a usable TLS cert/key "
             "pair is supplied via CLI or configuration.",
    )
    https_group.add_argument(
        "--no-https", action="store_true", dest="no_https", default=False,
        help="Force plaintext HTTP even if the configuration would "
             "otherwise enable HTTPS.",
    )
    p.add_argument(
        "--tls-cert", dest="tls_cert", default=None,
        help="Path to a PEM certificate (or fullchain).  Implies --https. "
             "Use together with --tls-key.",
    )
    p.add_argument(
        "--tls-key", dest="tls_key", default=None,
        help="Path to the matching PEM private key.  Set "
             "PASLA_TLS_KEY_PASSWORD in the environment if the key is "
             "encrypted.",
    )
    checksum_group = p.add_mutually_exclusive_group()
    checksum_group.add_argument(
        "--checksum", action="store_true", default=None,
        dest="checksum",
        help="Force SHA-256 checksum computation (default for files <= 1 GB).",
    )
    checksum_group.add_argument(
        "--no-checksum", action="store_false", dest="checksum",
        help="Disable SHA-256 checksum even for small files.",
    )
    p.add_argument("--dry-run", action="store_true", dest="dry_run",
                   help="Validate arguments, resolve IPs, print URL, then exit.")
    p.add_argument(_DAEMON_FLAG, action="store_true",
                   dest="daemon", help=argparse.SUPPRESS)
    p.add_argument(_INSTANCE_ID_FLAG, dest="forced_instance_id",
                   default=None, help=argparse.SUPPRESS)
    p.add_argument(_TEMP_TAR_FLAG, dest="temp_tar",
                   default=None, help=argparse.SUPPRESS)
    return p


def _build_stop_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="pasla stop",
                                description="Stop one or all active instances.")
    p.add_argument("id",    nargs="?", help="Instance ID to stop.")
    p.add_argument("--all", action="store_true", dest="stop_all",
                   help="Stop all active instances.")
    return p


# ---------------------------------------------------------------------------
# Config file support
#
# Reads an optional INI config file for default values.  Never creates
# or modifies the file - read-only.
#   POSIX:   ~/.config/pasla
#   Windows: %USERPROFILE%\.pasla
#   Override: PASLA_CONFIG environment variable
# ---------------------------------------------------------------------------

def _config_path() -> Path | None:
    """Return the platform-native config file path, or None if unresolvable."""
    env = os.environ.get("PASLA_CONFIG")
    if env:
        return Path(env)
    if os.name == "nt":
        home = os.environ.get("USERPROFILE", "")
        if home:
            return Path(home) / ".pasla"
    else:
        home = os.environ.get("HOME", "")
        if home:
            return Path(home) / ".config" / "pasla"
    return None


def _load_config() -> dict[str, dict[str, str]]:
    """Load config from the platform path.  Returns nested dict or empty."""
    path = _config_path()
    if path is None or not path.is_file():
        return {}
    cp = configparser.ConfigParser()
    try:
        cp.read(str(path), encoding="utf-8")
        return {s: dict(cp[s]) for s in cp.sections()}
    except (configparser.Error, OSError, UnicodeDecodeError):
        log.warning("Could not parse config file %s, ignoring.", path)
        return {}


# ---------------------------------------------------------------------------
# SHA-256 checksum
# ---------------------------------------------------------------------------

def _compute_file_hash(
    path: str,
    show_progress: bool = False,
) -> tuple[str, str]:
    """Compute SHA-256 of a file using chunked reads.

    Returns (hex_digest, base64_digest).
    show_progress: print \\r progress line to stdout (foreground only).
    """
    h = hashlib.sha256()
    file_size = os.path.getsize(path)
    processed = 0
    with open(path, "rb") as f:
        while True:
            chunk = f.read(CHUNK_SIZE)
            if not chunk:
                break
            h.update(chunk)
            processed += len(chunk)
            if show_progress and file_size > 0:
                pct = int(processed * 100 / file_size)
                print(f"\r  Hashing: {pct}%", end="", flush=True)
    if show_progress:
        print("\r" + " " * 30 + "\r", end="", flush=True)
    hex_dig = h.hexdigest()
    b64_dig = base64.b64encode(h.digest()).decode("ascii")
    return hex_dig, b64_dig


# ---------------------------------------------------------------------------
# HTTPS: ephemeral self-signed certificate generation
# ---------------------------------------------------------------------------

@functools.lru_cache(maxsize=1)
def _find_openssl() -> str:
    """Locate the openssl binary. PATH first, then common installation fallbacks."""
    import shutil

    found = shutil.which("openssl")
    if found:
        return found

    if os.name == "nt":
        pf64 = os.environ.get("ProgramFiles", r"C:\Program Files")
        pf32 = os.environ.get("ProgramFiles(x86)", r"C:\Program Files (x86)")

        for path in (
            os.path.join(pf64, "Git", "mingw64", "bin", "openssl.exe"),
            os.path.join(pf32, "Git", "mingw32", "bin", "openssl.exe"),
            os.path.join(pf64, "Git", "usr", "bin", "openssl.exe"),
            os.path.join(pf32, "Git", "usr", "bin", "openssl.exe"),
            os.path.join(pf64, "OpenSSL-Win64", "bin", "openssl.exe"),
            os.path.join(pf32, "OpenSSL-Win32", "bin", "openssl.exe"),
            os.path.join(pf64, "OpenSSL", "bin", "openssl.exe"),
            os.path.join(pf32, "OpenSSL", "bin", "openssl.exe"),
        ):
            if os.path.isfile(path):
                return path

    raise FileNotFoundError(
        "openssl binary not found. Install Git for Windows or OpenSSL and ensure it is on PATH."
    )


def _generate_ephemeral_cert(cert_dir: str) -> tuple[str, str]:
    """Generate a self-signed ECDSA certificate via openssl subprocess.

    Returns (cert_path, key_path).
    Raises FileNotFoundError if openssl is not on PATH.
    Raises subprocess.CalledProcessError if openssl fails.
    """
    cert_path = os.path.join(cert_dir, "cert.pem")
    key_path = os.path.join(cert_dir, "key.pem")
    openssl_bin = _find_openssl()

    try:
        subprocess.run(
            [
                openssl_bin, "req", "-x509",
                "-newkey", "ec",
                "-pkeyopt", "ec_paramgen_curve:prime256v1",
                "-keyout", key_path,
                "-out", cert_path,
                "-days", str(HTTPS_CERT_VALIDITY_DAYS),
                "-nodes",
                "-subj", "/CN=pasla",
            ],
            check=True,
            capture_output=True,
            timeout=OPENSSL_GEN_TIMEOUT,
        )
    except FileNotFoundError:
        log.error(
            "--https requires the openssl CLI tool on PATH.\n"
            "  Linux/macOS: usually pre-installed.\n"
            "  Windows: install Git for Windows or OpenSSL (winget install \"OpenSSL Light\")."
        )
        raise
    except subprocess.CalledProcessError as e:
        stderr_text = e.stderr.decode("utf-8", errors="replace") if e.stderr else ""
        log.error(
            "openssl certificate generation failed (exit code %d):\n%s",
            e.returncode, stderr_text,
        )
        raise

    # Restrict private key to owner-only on POSIX.
    if os.name != "nt":
        try:
            os.chmod(key_path, 0o600)
            os.chmod(cert_path, 0o600)
        except OSError:
            pass

    return cert_path, key_path


def _get_cert_fingerprint(cert_path: str) -> str:
    """Return the SHA-256 fingerprint of a PEM certificate."""
    try:
        openssl_bin = _find_openssl()
        result = subprocess.run(
            [openssl_bin, "x509", "-in", cert_path,
             "-noout", "-fingerprint", "-sha256"],
            capture_output=True, text=True, timeout=OPENSSL_QUERY_TIMEOUT,
        )
        # Output: SHA256 Fingerprint=AA:BB:CC:...
        for line in result.stdout.splitlines():
            if "=" in line:
                return line.split("=", 1)[1].strip()
    except (OSError, subprocess.TimeoutExpired):
        pass
    return "(unknown)"


# ---------------------------------------------------------------------------
# OSC 8 hyperlink (clickable URLs in modern terminals)
# ---------------------------------------------------------------------------

def _osc8_link(url: str) -> str:
    """Wrap a URL in OSC 8 escape sequences for terminal hyperlinks.

    Supported by Windows Terminal, iTerm2, GNOME Terminal, Konsole, Alacritty.
    Unsupported terminals silently ignore the escape sequences.

    Control characters (< 0x20) are stripped to prevent a crafted URL
    containing BEL (0x07) from prematurely terminating the OSC sequence
    and injecting arbitrary terminal escape codes.
    """
    safe = "".join(c for c in url if ord(c) >= 0x20)
    return f"\x1b]8;;{safe}\x07{safe}\x1b]8;;\x07"


def _safe_display(text: str) -> str:
    """Strip control characters from text before printing it to a terminal.

    File names and other externally-influenced strings can carry ANSI or
    OSC escape sequences.  Printed verbatim they let a crafted name
    rewrite the terminal title, move the cursor, or inject further
    escapes.  Removing every C0/C1 control character (and DEL) keeps
    terminal output strictly textual.
    """
    return "".join(
        c for c in text
        if ord(c) >= 0x20 and ord(c) != 0x7f and not (0x80 <= ord(c) <= 0x9f)
    )


def _enable_windows_ansi() -> None:
    """Enable VT100 escape processing on Win10+ console handles.

    cmd.exe / legacy Windows console renders ANSI escapes as raw
    text unless ``ENABLE_VIRTUAL_TERMINAL_PROCESSING`` (0x0004) is set
    on the stdout handle.  Win10 1607+ supports this; older Windows
    silently ignores ``SetConsoleMode`` and the banner falls back to
    showing literal escape codes (cosmetic only).  Implemented via
    ``ctypes`` to keep the standard-library-only constraint.
    """
    if os.name != "nt":
        return
    try:
        import ctypes

        kernel32 = ctypes.windll.kernel32
        STD_OUTPUT_HANDLE = -11
        ENABLE_VIRTUAL_TERMINAL_PROCESSING = 0x0004
        handle = kernel32.GetStdHandle(STD_OUTPUT_HANDLE)
        mode = ctypes.c_ulong()
        if kernel32.GetConsoleMode(handle, ctypes.byref(mode)):
            kernel32.SetConsoleMode(
                handle, mode.value | ENABLE_VIRTUAL_TERMINAL_PROCESSING,
            )
    except (OSError, AttributeError):
        log.debug("Failed to enable Windows ANSI mode", exc_info=True)


def _tar_directory(directory: str) -> str:
    """Archive a directory into a plain tar under REGISTRY_DIR, return the tar path.

    Uses uncompressed tar (``tarfile.open(…, 'w')``) so the archive is
    created at full I/O speed.  Users who need compression or encryption
    can post-process the tar with their preferred tool (gzip, 7z, gpg).

    A ``.pasla_lock`` file containing the current PID is written into the
    temporary directory immediately after creation.  This prevents
    ``_sweep_orphan_artifacts`` (invoked by ``pasla list``) from deleting
    the directory while archiving is in progress - the sweep checks the
    lock and skips directories whose owning PID is still alive.
    """
    dir_name = os.path.basename(os.path.normpath(directory))
    REGISTRY_DIR.mkdir(parents=True, exist_ok=True)
    tmp_dir = REGISTRY_DIR / f".tmp_{secrets.token_hex(TMP_DIR_SUFFIX_BYTES)}"
    tmp_dir.mkdir(parents=True, exist_ok=True)
    _write_lock_file(tmp_dir)
    tar_path = tmp_dir / f"{dir_name}.tar"

    # Single pass - collect file list once to avoid race conditions.
    entries: list[tuple[str, str]] = []
    total_size = 0
    for root, _dirs, files in os.walk(directory, followlinks=False):
        for f in files:
            full = os.path.join(root, f)
            if os.path.isfile(full) and not os.path.islink(full):
                arc = os.path.relpath(full, directory)
                entries.append((full, arc))
                total_size += os.path.getsize(full)

    total = len(entries)
    print(f"Archiving {total} files ({_fmt_bytes(total_size)})...", flush=True)
    try:
        with tarfile.open(tar_path, "w") as tf:
            # Security: explicitly disable dereferencing so a symlink is
            # archived as a link and never followed to read sensitive
            # system file content.
            tf.dereference = False
            added = 0
            for full, arc_name in entries:
                # Re-check each entry right before adding it.  If the
                # path was swapped for a symlink (or otherwise stopped
                # being a regular file) between the initial walk and
                # now, skip it entirely rather than archive the link.
                if os.path.islink(full) or not os.path.isfile(full):
                    log.warning(
                        "Skipping %s: no longer a regular file at "
                        "archive time.", arc_name,
                    )
                    continue
                tf.add(full, arcname=arc_name)
                added += 1
                print(f"\r  {added}/{total} files", end="", flush=True)
    except OSError:
        # OSError covers disk full / permission denied while writing
        # individual entries.  Clean up the partial tar and temp
        # directory on failure.  The .pasla_lock file written at
        # directory creation must go first - rmdir on a non-empty
        # directory always fails with ENOTEMPTY.
        try:
            os.unlink(tar_path)
        except OSError:
            log.debug("Failed to remove partial tar %s", tar_path, exc_info=True)
        try:
            os.unlink(tmp_dir / ".pasla_lock")
        except OSError:
            log.debug("Failed to remove lock file in %s", tmp_dir, exc_info=True)
        try:
            os.rmdir(tmp_dir)
        except OSError:
            log.debug("Failed to remove temp dir %s", tmp_dir, exc_info=True)
        raise
    tar_size = os.path.getsize(tar_path)
    print(f"\r  Archived to {_fmt_bytes(tar_size)}" + " " * 20)
    return str(tar_path)


def parse_and_validate() -> argparse.Namespace:
    """
    Manual dispatch so that positional file arguments never clash with
    subcommand names.

    Recognised subcommands : list, stop
    Everything else        : treated as a file path (serve mode)
    """
    argv = sys.argv[1:]

    # Extract internal daemon flag before dispatch.
    is_daemon = _DAEMON_FLAG in argv
    argv      = [a for a in argv if a != _DAEMON_FLAG]

    if not argv:
        _build_serve_parser().print_usage()
        print("Run 'pasla --help' for detailed usage information.")
        sys.exit(0)

    first = argv[0]

    if first == "list":
        # Handle --help for the list subcommand.
        if len(argv) > 1 and argv[1] in ("-h", "--help"):
            print("usage: pasla list\n\nList active pasla instances.")
            sys.exit(0)
        ns            = argparse.Namespace()
        ns.subcommand = "list"
        return ns

    if first == "stop":
        p   = _build_stop_parser()
        sub = p.parse_args(argv[1:])
        if not sub.id and not sub.stop_all:
            p.print_help()
            sys.exit(1)
        sub.subcommand = "stop"
        return sub

    # Default: serve mode.
    p    = _build_serve_parser()

    # Apply config file defaults BEFORE parsing so CLI always wins.
    cfg  = _load_config()
    srv  = cfg.get("server", {})
    sec  = cfg.get("security", {})
    tls  = cfg.get("tls", {})
    defaults: dict[str, object] = {}
    if "duration" in srv:
        try:
            defaults["duration"] = int(srv["duration"])
        except ValueError:
            pass
    if "max_downloads" in srv:
        try:
            defaults["max_downloads"] = int(srv["max_downloads"])
        except ValueError:
            pass
    if "port" in srv:
        try:
            defaults["port"] = int(srv["port"])
        except ValueError:
            pass
    if "ip_mode" in srv and srv["ip_mode"] in ("4", "6"):
        defaults["ip_mode"] = srv["ip_mode"]
    if sec.get("trust_proxy", "").lower() == "true":
        defaults["trust_proxy"] = True
    if "trust_header" in sec:
        defaults["trust_header"] = sec["trust_header"]
    if tls.get("https", "").lower() == "true":
        defaults["https"] = True
    # BYO TLS cert paths from configuration.  Either both keys must be
    # present or neither; the post-parse step below validates that the
    # files exist before honouring them.
    if "cert" in tls:
        defaults["tls_cert"] = tls["cert"]
    if "key" in tls:
        defaults["tls_key"] = tls["key"]
    if defaults:
        p.set_defaults(**defaults)

    args = p.parse_args(argv)
    args.subcommand = None
    args.daemon     = is_daemon
    # Update check is opt-out: enabled unless [update] check is explicitly
    # false in the config file.  No CLI flag and no env var by design -
    # the user disables it deliberately by editing their own config.
    args.update_check = (
        cfg.get("update", {}).get("check", "true").strip().lower() != "false"
    )

    # Resolve TLS posture from the union of CLI flags, config defaults,
    # and on-disk reachability of the supplied cert/key pair.  Order of
    # operations:
    #   1. ``--no-https`` is the hard override - clears any TLS state.
    #   2. A CLI/config-supplied cert/key pair that resolves to readable
    #      regular files implies ``--https`` automatically; this is the
    #      "drop a Let's Encrypt path in your config and be done"
    #      ergonomic.
    #   3. If exactly one of cert/key is supplied, it is a configuration
    #      error - reject loudly rather than silently falling back to
    #      ephemeral mode.
    #   4. If both are supplied but at least one is unreachable, drop
    #      both and warn; honour ``--https`` separately if set, which
    #      will fall back to ephemeral generation.
    if getattr(args, "no_https", False):
        args.https = False
        args.tls_cert = None
        args.tls_key = None
    else:
        cert_supplied = bool(args.tls_cert)
        key_supplied = bool(args.tls_key)
        if cert_supplied != key_supplied:
            log.error(
                "TLS configuration error: --tls-cert and --tls-key must "
                "both be set or neither.  Got cert=%r key=%r.",
                args.tls_cert, args.tls_key,
            )
            sys.exit(1)
        if cert_supplied and key_supplied:
            cert_real = _resolve_tls_path(args.tls_cert, "cert")
            key_real = _resolve_tls_path(args.tls_key, "key")
            if cert_real and key_real:
                args.tls_cert = cert_real
                args.tls_key = key_real
                if not args.https:
                    log.info(
                        "Auto-enabling HTTPS using configured TLS "
                        "cert (%s) and key (%s).",
                        args.tls_cert, args.tls_key,
                    )
                args.https = True
            else:
                log.warning(
                    "Configured TLS cert/key is not readable; ignoring "
                    "and continuing without bring-your-own certificate.",
                )
                args.tls_cert = None
                args.tls_key = None

    resolved       = os.path.realpath(args.file)
    # normcase() ensures case-insensitive comparison on Windows/macOS
    # where 'C:\Users' and 'c:\users' refer to the same directory.
    allowed_prefix = os.path.normcase(ALLOWED_ROOT + os.sep)

    # SECURITY GATE: this path confinement check MUST precede any
    # file-system interaction (including _resolve_target) to prevent
    # path traversal beyond the working directory.
    if (os.path.normcase(resolved) != os.path.normcase(ALLOWED_ROOT)
            and not os.path.normcase(resolved).startswith(allowed_prefix)):
        log.error(
            "Resolved path '%s' is outside the allowed root '%s'. "
            "Sharing files outside the working directory is not permitted.",
            resolved, ALLOWED_ROOT,
        )
        sys.exit(1)

    resolved = _resolve_target(resolved, args)

    args.resolved_file    = resolved
    args.duration_seconds = args.duration * 60

    # --single convenience: force max_downloads=1.
    if args.single:
        if args.max_downloads not in (0, 1):
            log.warning("--single overrides max_downloads=%d to 1.", args.max_downloads)
        args.max_downloads = 1

    # --allow-ip CIDR validation.
    args.allowed_networks = None
    if args.allow_cidrs:
        nets = []
        for cidr in args.allow_cidrs:
            try:
                nets.append(ipaddress.ip_network(cidr, strict=False))
            except ValueError:
                log.error("Invalid --allow-ip value: %s", cidr)
                sys.exit(1)
        args.allowed_networks = nets

    # Port validation - reject negative values early.
    if getattr(args, "port", None) is not None and args.port < 0:
        log.error("Port must be 0 or a positive integer, got %d.", args.port)
        sys.exit(1)

    # --trust-header validation.
    trust_header = getattr(args, "trust_header", None)
    if trust_header:
        if not args.trust_proxy:
            log.warning(
                "--trust-header has no effect without --trust-proxy; ignoring."
            )
            args.trust_header = None
        elif trust_header not in TRUSTED_CLIENT_IP_HEADERS:
            log.warning(
                "--trust-header '%s' is not a well-known edge header. "
                "Known headers: %s.  Proceeding anyway.",
                trust_header, ", ".join(TRUSTED_CLIENT_IP_HEADERS),
            )

    # Checksum smart default: auto for files ≤ 1 GB, opt-in for larger.
    if args.checksum is None:
        file_size = os.path.getsize(args.resolved_file)
        args.checksum = file_size <= CHECKSUM_AUTO_THRESHOLD

    return args


# ---------------------------------------------------------------------------
# Registry (PID files)
#
# Each running instance writes a small JSON file to REGISTRY_DIR:
#
#   pasla_<id>.json
#   {
#     "id":        "a1b2c3",
#     "pid":       12345,
#     "ctrl_port": 52341
#   }
#
# The file is created at startup and removed in the finally block.
# All rich runtime state (URL, download count, etc.) is fetched live from
# the control plane - the registry file is only a pointer.
# ---------------------------------------------------------------------------

def _restrict_windows_acl(path, *, is_dir: bool = True) -> None:
    """Restrict a path to the current user on Windows via icacls.

    Equivalent to ``os.chmod(path, 0o700)`` (directory) or 0o600 (file)
    on POSIX.  On default Windows configurations ``%TEMP%`` is already
    per-user, but when the temp directory points to a shared location
    the inherited ACLs may grant read access to other local users -
    exposing ctrl_secret and the download URL.

    The ``(OI)(CI)F`` flags only make sense on directories
    (object/container inheritance).  When ``is_dir=False`` (e.g. a
    daemon log file) the inheritance flags are dropped and a plain
    ``F`` (full control) ACE is granted to the current user.
    """
    username = os.environ.get("USERNAME", "")
    if not username:
        return
    grant = f"{username}:(OI)(CI)F" if is_dir else f"{username}:F"
    try:
        subprocess.run(
            ["icacls", str(path), "/inheritance:r", "/grant", grant],
            capture_output=True, timeout=5,
        )
    except (OSError, subprocess.TimeoutExpired):
        log.warning("Failed to restrict Windows ACLs on %s. "
                    "Registry files may be readable by other local users.",
                    path, exc_info=True)


def _harden_registry_dir() -> None:
    """Create and secure REGISTRY_DIR before any artifacts are written."""
    REGISTRY_DIR.mkdir(parents=True, exist_ok=True)
    # Security: restrict directory to the current user.
    # Prevents other local users from reading ctrl_port / ctrl_secret
    # and connecting to the control plane to steal the download URL.
    if os.name == "nt":
        _restrict_windows_acl(REGISTRY_DIR)
    else:
        # Symlink defence: an attacker can pre-create a symlink
        # /tmp/pasla_registry_<uid> -> ~/.ssh so that mkdir(exist_ok)
        # silently succeeds (the target dir exists) and os.stat()
        # reports the victim's UID.  Check BEFORE the ownership test.
        if os.path.islink(REGISTRY_DIR):
            log.error(
                "Registry directory %s is a symlink. "
                "Possible symlink hijack attack. "
                "Delete the symlink or set $TMPDIR to a secure location.",
                REGISTRY_DIR,
            )
            sys.exit(1)
        try:
            os.chmod(REGISTRY_DIR, 0o700)
        except OSError:
            pass
        # Ownership validation: on multi-user POSIX systems with a
        # world-writable $TMPDIR (e.g. /tmp with sticky bit), an
        # attacker can pre-create the registry directory under their
        # own UID.  mkdir(exist_ok=True) silently succeeds, but
        # chmod() fails because only the owner can chmod.  Verify
        # that the directory is actually owned by us.  lstat() is
        # used instead of stat() to prevent a symlink from masking
        # the true owner - the islink() guard above already rejects
        # symlinks, but lstat() provides defence-in-depth.
        try:
            dir_uid = os.lstat(REGISTRY_DIR).st_uid
            if dir_uid != os.getuid():
                log.error(
                    "Registry directory %s is owned by UID %d, "
                    "expected %d. Possible directory squatting attack. "
                    "Delete the directory or set $TMPDIR to a secure location.",
                    REGISTRY_DIR, dir_uid, os.getuid(),
                )
                sys.exit(1)
        except OSError:
            log.debug("Could not verify ownership of %s", REGISTRY_DIR, exc_info=True)


def registry_path(instance_id: str) -> Path:
    _harden_registry_dir()
    return REGISTRY_DIR / f"pasla_{instance_id}.json"


def _resolve_target(resolved: str, args: argparse.Namespace) -> str:
    """Handle directory-archive prompt and verify file existence.

    Called after the ALLOWED_ROOT security gate has already passed.
    Returns the final file path (original or archived).
    """
    if os.path.isdir(resolved):
        try:
            answer = input(
                f'\n"{os.path.basename(resolved)}" is a directory. '
                f'Archive and share? [y/N]: '
            ).strip().lower()
        except EOFError:
            # No interactive TTY (e.g. invoked from a script with
            # stdin redirected to /dev/null).  Default to declining
            # so unattended pipelines never accidentally archive
            # large directories.
            log.error(
                "No interactive input available for directory archive "
                "prompt; aborting.  Pass an explicit file path or run "
                "interactively."
            )
            sys.exit(1)
        if answer != "y":
            sys.exit(0)
        resolved = _tar_directory(resolved)
        args.temp_tar = resolved

    if not os.path.isfile(resolved):
        # Log only the basename: the absolute path may identify the
        # invoking user's home directory in the daemon log, which is
        # readable by anyone with access to ``REGISTRY_DIR``.
        log.error("File not found: %s", os.path.basename(resolved))
        sys.exit(1)

    return resolved


def write_registry(instance_id: str, pid: int, ctrl_port: int,
                   temp_archive: str | None = None,
                   ctrl_secret: str | None = None) -> None:
    data: dict = {"id": instance_id, "pid": pid, "ctrl_port": ctrl_port}
    if temp_archive:
        data["temp_archive"] = temp_archive
    if ctrl_secret:
        data["ctrl_secret"] = ctrl_secret
    target = registry_path(instance_id)
    fd, tmp = tempfile.mkstemp(dir=REGISTRY_DIR, suffix=".tmp")
    closed = False
    try:
        # On POSIX, ``mkstemp`` honours the current umask so the temp
        # file may briefly be world-readable before ``os.replace``.
        # ``fchmod`` on the open descriptor is atomic with respect to
        # the file's identity - no other process can race in and open
        # the temp file under looser permissions.
        if os.name != "nt":
            try:
                os.fchmod(fd, 0o600)
            except OSError:
                log.debug("fchmod 0o600 failed on registry temp file",
                          exc_info=True)
        os.write(fd, json.dumps(data).encode("utf-8"))
        os.close(fd)
        closed = True
        # os.replace is atomic on every platform, but on Windows it
        # raises PermissionError when the target is momentarily held
        # open by a concurrent reader (e.g. `pasla list` reading the
        # registry JSON).  That open window is sub-millisecond, so a
        # single 20ms backoff clears it.  POSIX never hits this race -
        # a PermissionError there is a genuine fault, so it re-raises
        # immediately.
        for _attempt in range(2):
            try:
                os.replace(tmp, target)
                break
            except PermissionError:
                if os.name != "nt" or _attempt == 1:
                    raise
                time.sleep(0.02)
        # Security: restrict registry file to owner-only on POSIX.
        # The file contains ctrl_secret which grants control plane access.
        if os.name != "nt":
            try:
                os.chmod(target, 0o600)
            except OSError:
                log.debug(
                    "Post-replace chmod 0o600 failed on registry file",
                    exc_info=True,
                )
    except BaseException:
        if not closed:
            os.close(fd)
        try:
            os.unlink(tmp)
        except OSError:
            log.debug("Failed to unlink temp file %s", tmp, exc_info=True)
        raise


def delete_registry(instance_id: str) -> None:
    try:
        registry_path(instance_id).unlink(missing_ok=True)
    except OSError:
        pass


def _registry_entry_is_valid(entry: object) -> bool:
    """Defense-in-depth schema check on registry JSON.

    A same-UID attacker who can write into REGISTRY_DIR cannot be
    fully prevented from tampering with these files (they need to
    be readable by the user to be useful at all), but the consumers
    of this data - ``pasla list``, ``pasla stop``, ``cmd_detach`` -
    benefit from rejecting malformed shapes here so they never
    have to defend against them downstream.  In particular,
    ``socket.create_connection`` raises a confusing error when
    handed a port outside 1-65535, and ``pid_is_alive`` would
    waste a syscall on a clearly-bogus PID.
    """
    if not isinstance(entry, dict):
        return False
    pid = entry.get("pid")
    if not isinstance(pid, int) or pid <= 0:
        return False
    ctrl_port = entry.get("ctrl_port")
    if not isinstance(ctrl_port, int) or not 1 <= ctrl_port <= 65535:
        return False
    inst_id = entry.get("id")
    if not isinstance(inst_id, str) or not inst_id:
        return False
    return True


def read_all_registry() -> list[dict]:
    # Harden the directory (ownership + permissions + symlink rejection)
    # before reading it, so list/stop are protected by the same checks
    # the serve path applies.
    _harden_registry_dir()
    entries = []
    for p in REGISTRY_DIR.glob("pasla_*.json"):
        try:
            data = json.loads(p.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            continue
        if not _registry_entry_is_valid(data):
            log.warning(
                "Skipping registry entry %s: schema validation failed.",
                p.name,
            )
            continue
        entries.append(data)
    return entries

# ---------------------------------------------------------------------------
# Process liveness check
#
# os.kill(pid, 0) works on all platforms:
#   - ProcessLookupError  → process does not exist
#   - PermissionError     → process exists but belongs to another user
#   - No exception        → process exists and is ours
# ---------------------------------------------------------------------------

def pid_is_alive(pid: int) -> bool:
    if sys.platform == "win32":
        import ctypes

        # Windows API Constants
        PROCESS_QUERY_LIMITED_INFORMATION = 0x1000
        STILL_ACTIVE = 259
        ERROR_ACCESS_DENIED = 5
        kernel32 = ctypes.windll.kernel32

        handle = kernel32.OpenProcess(
            PROCESS_QUERY_LIMITED_INFORMATION, 
            False, 
            pid
        )

        if not handle:
            # If access is denied, the process exists but belongs to a higher 
            # privilege context (e.g., System PID 4). Thus, it is alive.
            if kernel32.GetLastError() == ERROR_ACCESS_DENIED:
                return True
            return False 

        try:
            # Handle acquired, but the process might be a zombie.
            # We must check the exit code to ensure it is STILL_ACTIVE.
            exit_code = ctypes.c_ulong()
            success = kernel32.GetExitCodeProcess(handle, ctypes.byref(exit_code))
            if success:
                return exit_code.value == STILL_ACTIVE
            return False
        finally:
            # Guarantee handle closure to prevent resource leaks
            kernel32.CloseHandle(handle)

    # POSIX - signal 0 checks existence without affecting the process.
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        # Process exists but belongs to another user - still alive.
        return True
    except OSError:
        # Failsafe for unexpected OS errors (e.g., invalid PID ranges).
        return False

# ---------------------------------------------------------------------------
# Control plane client helpers
# ---------------------------------------------------------------------------

def _ctrl_send(ctrl_port: int, command: str,
               secret: str = "") -> dict | None:
    """
    Open a loopback TCP connection to ctrl_port, send a JSON command, and
    return the parsed JSON response.  Returns None on any error.
    """
    try:
        with socket.create_connection(("127.0.0.1", ctrl_port), timeout=CTRL_TIMEOUT) as s:
            payload = {"command": command}
            if secret:
                payload["secret"] = secret
            s.sendall((json.dumps(payload) + "\n").encode())
            buf = b""
            while b"\n" not in buf:
                chunk = s.recv(CTRL_MAX_MESSAGE_BYTES)
                if not chunk:
                    break
                buf += chunk
                if len(buf) > CTRL_MAX_RESPONSE_BYTES:
                    return None   # response too large - abort
            return json.loads(buf.split(b"\n")[0].decode())
    except (OSError, ValueError, json.JSONDecodeError, UnicodeDecodeError):
        return None


def ctrl_status(ctrl_port: int, secret: str = "") -> dict | None:
    return _ctrl_send(ctrl_port, "status", secret=secret)


def ctrl_stop(ctrl_port: int, secret: str = "") -> bool:
    resp = _ctrl_send(ctrl_port, "stop", secret=secret)
    return resp is not None and resp.get("status") == "shutting_down"

# ---------------------------------------------------------------------------
# Control plane server
#
# Runs in a background daemon thread inside each pasla instance.
# Listens on a random loopback port (127.0.0.1 only - never externally
# reachable) and handles one connection at a time.
#
# Security measures:
#   - Bound exclusively to 127.0.0.1; never 0.0.0.0 or ::
#   - Shared secret authentication via hmac.compare_digest -
#     prevents any local user from enumerating ports and issuing
#     commands to steal the download URL or shut down instances
#   - Command whitelist: only "status" and "stop" are accepted
#   - Inbound message size cap: CTRL_MAX_MESSAGE_BYTES
#   - Per-connection read deadline: CTRL_READ_TIMEOUT seconds
#   - Unknown or malformed commands return {"error": "unknown_command"}
#     without leaking internal state
# ---------------------------------------------------------------------------

def start_control_plane(
    instance_id: str,
    get_status_fn,          # callable () -> dict
    stop_fn,                # callable () -> None
    ctrl_secret: str,       # shared secret for authentication (required)
) -> tuple[int, threading.Thread]:
    """
    Bind a control plane socket on a random loopback port and start the
    handler loop in a daemon thread.  Returns ``(port, thread)`` so the
    caller can monitor thread health.

    ``ctrl_secret`` MUST be a non-empty string.  An empty secret would
    make ``hmac.compare_digest(secret_input, "")`` succeed for a client
    that simply sends ``"secret": ""``, silently disabling control-plane
    authentication - so it is rejected up front rather than left as a
    latent bypass.
    """
    if not ctrl_secret:
        raise ValueError("start_control_plane requires a non-empty ctrl_secret")
    srv_sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    try:
        # On Windows, ``SO_REUSEADDR`` allows a second process to bind
        # the same port simultaneously and intercept incoming
        # control-plane connections - a hijack vector for a same-UID
        # attacker.  ``SO_EXCLUSIVEADDRUSE`` reserves the port for
        # this process exclusively, mirroring the (already-safe) POSIX
        # ``SO_REUSEADDR`` semantics that we keep below.
        if os.name == "nt" and hasattr(socket, "SO_EXCLUSIVEADDRUSE"):
            srv_sock.setsockopt(socket.SOL_SOCKET, socket.SO_EXCLUSIVEADDRUSE, 1)
        else:
            srv_sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        srv_sock.bind(("127.0.0.1", 0))
        srv_sock.listen(CTRL_LISTEN_BACKLOG)
    except OSError:
        srv_sock.close()
        raise
    ctrl_port = srv_sock.getsockname()[1]

    def _handle_ctrl_connection(conn) -> bool:
        """Service a single control-plane connection.

        Returns True if the caller should exit the accept loop
        (currently only the ``stop`` command requests this); False
        otherwise.  All wire-level errors are absorbed so a single
        misbehaving client cannot kill the daemon thread.
        """
        conn.settimeout(CTRL_READ_TIMEOUT)
        # Absolute deadline: settimeout() limits each individual recv()
        # call, but a slow-read attacker can trickle bytes just fast
        # enough to keep every recv() under the per-call limit.  The
        # deadline enforces a hard wall-clock cap on the whole message.
        # Without it, a connection that never completes a command could
        # occupy the single-threaded accept loop and stall `pasla list`
        # / `pasla stop`.
        deadline = time.monotonic() + CTRL_READ_TIMEOUT
        buf = b""
        while b"\n" not in buf:
            if time.monotonic() > deadline:
                return False
            chunk = conn.recv(CTRL_MAX_MESSAGE_BYTES)
            if not chunk:
                break
            buf += chunk
            if len(buf) > CTRL_MAX_MESSAGE_BYTES:
                conn.sendall(
                    (json.dumps({"error": "message_too_large"}) + "\n").encode(),
                )
                return False

        line = buf.split(b"\n")[0]
        try:
            msg = json.loads(line.decode())
        except (json.JSONDecodeError, UnicodeDecodeError):
            conn.sendall(
                (json.dumps({"error": "invalid_json"}) + "\n").encode(),
            )
            return False

        # Non-dict payloads (JSON arrays, strings, numbers, etc.) are
        # rejected explicitly.  ``msg.get`` would otherwise raise
        # ``AttributeError`` on a list and kill the daemon thread,
        # permanently disabling the control plane.
        if not isinstance(msg, dict):
            conn.sendall(
                (json.dumps({"error": "invalid_json"}) + "\n").encode(),
            )
            return False

        command = msg.get("command", "")

        # Constant-time secret check before any command dispatch so
        # the wrong-secret response time does not leak which prefix
        # was correct.
        secret_input = msg.get("secret")
        if not isinstance(secret_input, str) or not hmac.compare_digest(
            secret_input, ctrl_secret,
        ):
            conn.sendall(
                (json.dumps({"error": "auth_failed"}) + "\n").encode(),
            )
            return False

        if command not in CTRL_ALLOWED_COMMANDS:
            conn.sendall(
                (json.dumps({"error": "unknown_command"}) + "\n").encode(),
            )
            return False

        if command == "status":
            response = (json.dumps(get_status_fn()) + "\n").encode()
            # Refuse to truncate: a half-written JSON body makes the
            # client decoder fail and the caller declare the
            # instance stale, deleting an otherwise-healthy registry
            # entry.  Surface the size error explicitly so the
            # caller can react and operators see the cause in logs.
            if len(response) > CTRL_MAX_MESSAGE_BYTES:
                log.warning(
                    "Control plane status response is %d bytes "
                    "(cap %d); replying with response_too_large.",
                    len(response), CTRL_MAX_MESSAGE_BYTES,
                )
                response = (
                    json.dumps({"error": "response_too_large"}) + "\n"
                ).encode()
            conn.sendall(response)
            return False

        if command == "stop":
            conn.sendall(
                (json.dumps({"status": "shutting_down"}) + "\n").encode(),
            )
            stop_fn()
            return True

        return False

    def _handler_loop() -> None:
        while not shutting_down.is_set():
            try:
                srv_sock.settimeout(CTRL_POLL_INTERVAL)
                try:
                    conn, addr = srv_sock.accept()
                except socket.timeout:
                    continue

                # Only allow connections from 127.0.0.1.
                if addr[0] != "127.0.0.1":
                    conn.close()
                    log.warning(
                        "Control plane rejected non-loopback connection from %s",
                        addr[0],
                    )
                    continue

                with conn:
                    try:
                        if _handle_ctrl_connection(conn):
                            break
                    except (OSError, socket.timeout):
                        log.debug("Control plane connection error",
                                  exc_info=True)
                    except Exception:
                        # Anything raised while servicing a single
                        # connection - JSON bugs in the status payload,
                        # callable side-effects in get_status_fn /
                        # stop_fn, etc. - is absorbed.  The control
                        # plane is the ONLY way to issue ``pasla stop``
                        # against a running daemon, so the accept loop
                        # must outlive any per-connection failure.
                        log.error(
                            "Unhandled control plane error; dropping connection.",
                            exc_info=True,
                        )

            except OSError:
                break
            except Exception:
                # Same reasoning as above but at the ``accept()``
                # layer: keep the loop alive across unexpected
                # failures so the daemon stays controllable.
                log.error(
                    "Unhandled control plane accept error; continuing.",
                    exc_info=True,
                )

        srv_sock.close()

    t = threading.Thread(target=_handler_loop, daemon=True, name="ctrl-plane")
    t.start()
    return ctrl_port, t

# ---------------------------------------------------------------------------
# IP resolution
# ---------------------------------------------------------------------------

def _parse_ip_or_none(candidate: str) -> str | None:
    """Return ``candidate`` if it parses as a valid IP, else ``None``."""
    candidate = candidate.strip()
    if not candidate:
        return None
    try:
        ipaddress.ip_address(candidate)
    except ValueError:
        return None
    return candidate


def get_client_ip(handler: BaseHTTPRequestHandler, trust_proxy: bool,
                  trust_header: str | None = None) -> str:
    """Return the originating client IP for this request.

    With ``trust_proxy=False`` the raw TCP peer address is returned
    unconditionally - header-based controls are off.

    With ``trust_proxy=True`` and ``trust_header`` set, the named
    header is checked first; this is the preferred configuration
    when the edge provider is known (e.g. Cloudflare →
    ``CF-Connecting-IP``).  When ``trust_header`` is not set or the
    header is absent / invalid, the rightmost entry of
    ``X-Forwarded-For`` is used - the universal standard that every
    reverse proxy populates.  When all header sources fail, the
    function falls back to the TCP peer address so the request is
    never routed without an attributable identity.

    Header merging
    ~~~~~~~~~~~~~~
    Some proxies add a *new* header line instead of comma-appending to
    an existing one.  Python's ``headers.get()`` returns only the first
    occurrence, which an attacker controls.  We therefore use
    ``headers.get_all()`` and merge/select accordingly:

    * **X-Forwarded-For** - all lines concatenated with ``,``, then
      the rightmost (last) entry is extracted.
    * **Single-value headers** (``--trust-header``) - the *last*
      occurrence is used, since the edge proxy writes after the
      client's headers in the HTTP message.
    """
    socket_ip = handler.client_address[0]
    if not trust_proxy:
        return socket_ip

    if trust_header:
        # Single-value edge headers: the proxy writes after the
        # client, so the last occurrence is the legitimate one.
        all_vals = handler.headers.get_all(trust_header, [])
        if all_vals:
            candidate = _parse_ip_or_none(all_vals[-1])
            if candidate is not None:
                return candidate

    # X-Forwarded-For: concatenate all header lines (some proxies
    # add a new line instead of comma-appending to the existing one),
    # then take the rightmost entry - that is the IP the closest
    # trusted proxy appended.
    xff_parts = handler.headers.get_all("X-Forwarded-For", [])
    if xff_parts:
        combined = ",".join(xff_parts)
        candidate = _parse_ip_or_none(combined.split(",")[-1])
        if candidate is not None:
            return candidate

    return socket_ip


def _ip_in_allowlist(
    addr: ipaddress.IPv4Address | ipaddress.IPv6Address,
    allowed_networks: list,
) -> bool:
    """Return True iff ``addr`` falls inside any of ``allowed_networks``.

    Iterates the network list once; the caller pays for the entries
    they configured (typical deployments use < 10 CIDRs so a linear
    scan is faster than building an interval tree).
    """
    return any(addr in net for net in allowed_networks)

# ---------------------------------------------------------------------------
# Unified request validation (single lock acquisition)
# ---------------------------------------------------------------------------

def _validate_and_register_request(
    client_ip: str, socket_ip: str | None = None,
    authenticated: bool = False,
) -> tuple[int, str] | None:
    """Check ban, rate-limit, and per-IP connection cap.

    Returns ``None`` if the request may proceed, otherwise
    ``(http_status, reason)`` where ``reason`` identifies the gate
    that fired.  Telemetry surfaces ``reason`` so operators can tell
    a banned IP apart from a rate-limit hit when triaging logs.

    ``authenticated`` is True when the caller has already confirmed the
    request carries the correct URL token.  Such a request is a genuine
    download, not abusive traffic, so the request-rate limit is neither
    checked nor advanced for it - a client legitimately fetching many
    ranges or segments is never throttled.  Bans and connection caps
    still apply, since those bound concurrency and blocklisted peers
    regardless of authentication.

    When ``socket_ip`` is provided and differs from ``client_ip``
    (i.e. ``trust_proxy=True``), three independent gates apply:

      * ban list - checked against BOTH the XFF client IP and the
        underlying TCP peer IP.  Closes the XFF-rotation evasion
        vector: failures recorded against the socket IP eventually
        ban the peer regardless of header rotation.
      * per-XFF rate-limit and per-XFF connection cap - preserved so
        a legitimate reverse proxy multiplexing many real clients is
        not penalised when one of those clients is noisy.
      * per-proxy aggregate rate-limit and connection cap - applied
        to the socket IP only when it differs from ``client_ip``.
        These ceilings are deliberately wider than the per-XFF
        limits and exist to bound a single misbehaving (or
        compromised) peer that rotates XFF on every request.
    """
    now = time.monotonic()
    with security_lock:
        if client_ip in banned_ips:
            return 403, "banned_client_ip"
        if (socket_ip is not None and socket_ip != client_ip
                and socket_ip in banned_ips):
            return 403, "banned_socket_ip"

    proxy_scope = (socket_ip is not None and socket_ip != client_ip)

    with rate_lock:
        is_tracked = client_ip in request_log
        if not authenticated and is_tracked:
            request_log[client_ip] = [t for t in request_log[client_ip]
                                      if now - t < RATE_LIMIT_WINDOW]
            if len(request_log[client_ip]) >= RATE_LIMIT_MAX_REQUESTS:
                return 429, "rate_limit_client_ip"

        # ``.get(..., 0)`` rather than ``[ip]`` so a cap-check from a
        # never-before-seen IP does not autovivify a defaultdict
        # entry.  Rotating-IP probes would otherwise leak one entry
        # per source address until the next cleanup_state pass, on
        # top of any tracking already done by request_log.
        #
        # ``> limit`` (not ``>=``): the counter already includes this
        # connection, so a count equal to the limit means we are AT the
        # ceiling, not over it.  This matches the pre-header gate in
        # ``handle()`` so both checks enforce one consistent ceiling.
        if active_connections.get(client_ip, 0) > MAX_CONNECTIONS_PER_IP:
            return 429, "conn_cap_client_ip"

        if proxy_scope:
            if not authenticated:
                # Aggregate proxy-peer rate-limit.  Tracked under the
                # same ``request_log`` map but keyed by socket IP,
                # which is always distinct from ``client_ip`` here, so
                # the per-XFF bookkeeping above is unaffected.
                proxy_log = request_log.get(socket_ip)
                if proxy_log is not None:
                    request_log[socket_ip] = [t for t in proxy_log
                                              if now - t < RATE_LIMIT_WINDOW]
                    if len(request_log[socket_ip]) >= MAX_REQUESTS_PER_PROXY_IP:
                        return 429, "rate_limit_proxy_ip"

            # ``> limit`` for the same reason as the per-client check
            # above - consistent with the pre-header gate in handle().
            if (active_connections.get(socket_ip, 0)
                    > MAX_CONNECTIONS_PER_PROXY_IP):
                return 429, "conn_cap_proxy_ip"

        # An authenticated request is never written to the rate-limit
        # log, so it neither trips nor advances the window.
        if authenticated:
            return None

        if is_tracked:
            request_log[client_ip].append(now)
        else:
            # Evict oldest entry when at capacity to prevent fail-open:
            # without eviction, an attacker with a large IP pool could
            # fill the table and bypass rate limiting for new IPs.
            if len(request_log) >= MAX_TRACKED_IPS:
                oldest_ip = next(iter(request_log))
                del request_log[oldest_ip]
            request_log[client_ip] = [now]

        if proxy_scope:
            # Append the socket-IP timestamp last so the per-XFF
            # decisions above were made against the unmodified table.
            if socket_ip in request_log:
                request_log[socket_ip].append(now)
            else:
                if len(request_log) >= MAX_TRACKED_IPS:
                    oldest_ip = next(iter(request_log))
                    del request_log[oldest_ip]
                request_log[socket_ip] = [now]

        return None


def _record_failure(client_ip: str, socket_ip: str | None = None) -> None:
    """Increment failure count for client_ip and, when distinct, socket_ip.

    Recording failures against the socket IP under ``trust_proxy=True``
    is the primary defence against XFF rotation: a single TCP peer
    sending many wrong-token requests with rotating XFF headers will
    still cross BAN_THRESHOLD on the socket IP within BAN_THRESHOLD
    failures, ending the attack regardless of header rotation.
    """
    ips = [client_ip]
    if socket_ip is not None and socket_ip != client_ip:
        ips.append(socket_ip)
    with security_lock:
        for ip in ips:
            if ip not in failed_attempts:
                # Evict oldest entry when at capacity so every new IP is
                # tracked.  Fail-open (skipping) would let an attacker
                # with many IPs brute-force the token without ever being banned.
                if len(failed_attempts) >= MAX_TRACKED_IPS:
                    oldest_ip = next(iter(failed_attempts))
                    del failed_attempts[oldest_ip]
            failed_attempts[ip] += 1
            if failed_attempts[ip] >= BAN_THRESHOLD:
                # When the ban list is full, evict the oldest entry
                # (LRU) instead of dropping the new ban.  Without
                # eviction, an attacker who fills the table with
                # disposable IPs would permanently disable bans for
                # every subsequent attacker.  Bans remain permanent
                # within the cap; only overflow triggers eviction.
                if len(banned_ips) >= MAX_BANNED_IPS:
                    evicted, _ = banned_ips.popitem(last=False)
                    log.warning(
                        "Ban list full. Evicting oldest ban (%s) to ban %s.",
                        evicted, ip,
                    )
                banned_ips.add(ip)
                log.warning("Banned IP after %d failed attempts: %s", BAN_THRESHOLD, ip)




def _try_increment_global_connections() -> bool:
    """Atomically check limit and increment. Returns False if at capacity."""
    with rate_lock:
        global global_connections
        if global_connections >= MAX_GLOBAL_CONNECTIONS:
            return False
        global_connections += 1
        return True


def _decrement_global_connections() -> None:
    with rate_lock:
        global global_connections
        global_connections = max(0, global_connections - 1)

def _increment_connections(ip: str) -> None:
    with rate_lock:
        # Evict the oldest entry when the table is full, mirroring
        # request_log / failed_attempts.  Without this bound a flood of
        # unique source IPs could grow the map without limit between
        # the periodic cleanup passes.
        if (ip not in active_connections
                and len(active_connections) >= MAX_TRACKED_IPS):
            oldest_ip = next(iter(active_connections))
            del active_connections[oldest_ip]
        active_connections[ip] += 1

def _decrement_connections(ip: str) -> None:
    with rate_lock:
        active_connections[ip] = max(0, active_connections[ip] - 1)

# ---------------------------------------------------------------------------
# Transfer-ID quota management
# ---------------------------------------------------------------------------

def _register_transfer(transfer_id: str) -> None:
    with transfer_lock:
        active_transfers[transfer_id] = _SLOT_REGISTERED


def _ensure_slot_reserved(transfer_id: str, max_downloads: int) -> bool:
    with transfer_lock:
        state = active_transfers.get(transfer_id)
        if state == _SLOT_IN_USE:
            # Security: reject concurrent use of the same transfer_id.
            # A race condition allowed multiple simultaneous requests
            # with the same X-Transfer-ID to bypass the download cap -
            # the first request consumed the slot, and all subsequent
            # ones returned True without incrementing download_count.
            return False
        if state == _SLOT_RESUMABLE:
            # An interrupted partial transfer already consumed a
            # download slot for this id.  A resume (client reconnects
            # with the same X-Transfer-ID and a Range header) reuses
            # that slot WITHOUT counting a second download against
            # max_downloads.  Without this branch a resumed download
            # was counted twice - and under --single (max_downloads=1)
            # a resume was rejected outright with 410.
            active_transfers[transfer_id] = _SLOT_IN_USE
            return True
        # state is _SLOT_REGISTERED (a freshly registered new transfer)
        # or None (a client-supplied X-Transfer-ID this server has
        # never seen, e.g. after a restart) - reserve a fresh slot.
        if max_downloads > 0:
            global download_count
            if download_count >= max_downloads:
                return False
            download_count += 1
        active_transfers[transfer_id] = _SLOT_IN_USE
        return True


def _release_transfer(transfer_id: str, completed: bool, max_downloads: int,
                      client_ip: str = "", bytes_sent: int = 0) -> None:
    """Release the slot held by ``transfer_id``.

    ``bytes_sent`` is the actual number of payload bytes that reached
    the wire, as reported by ``_stream_file``.  Outcomes:

      * completed transfer - the id is dropped, the slot stays spent.
      * aborted with zero bytes sent - the slot is refunded and the
        id dropped (nothing reached the client).
      * aborted after partial progress on a capped server - the slot
        stays spent and the id is parked in ``_SLOT_RESUMABLE`` so a
        continuation with the same X-Transfer-ID reuses it instead of
        being counted as a second download.  Bounded: the number of
        resumable entries can never exceed download_count, which is
        itself capped at max_downloads.
      * aborted after partial progress on an unlimited server - no
        slot accounting exists, so the id is simply dropped.

    Any progress at all consumes the slot so an attacker cannot burn
    bandwidth by repeatedly downloading 99% of the file and dropping
    the connection.
    """
    with transfer_lock:
        slot_consumed = active_transfers.get(transfer_id) == _SLOT_IN_USE
        if completed:
            # Track fully delivered transfers separately from slot
            # accounting: download_count only moves in capped mode, so
            # without this counter an unlimited server would report
            # zero downloads forever in the TUI and ``pasla list``.
            global completed_downloads
            completed_downloads += 1
            active_transfers.pop(transfer_id, None)
        elif slot_consumed and bytes_sent == 0:
            active_transfers.pop(transfer_id, None)
            if max_downloads > 0:
                global download_count
                download_count = max(0, download_count - 1)
        elif slot_consumed and max_downloads > 0:
            active_transfers[transfer_id] = _SLOT_RESUMABLE
        else:
            # Slot never reserved (cap was already full), or an
            # unlimited-mode partial abort with no slot to track.
            active_transfers.pop(transfer_id, None)
        if completed and client_ip:
            download_history.append((time.monotonic(), client_ip, bytes_sent))


def _current_download_count() -> int:
    with transfer_lock:
        return download_count


def _current_completed_downloads() -> int:
    with transfer_lock:
        return completed_downloads


def _add_bytes_transferred(n: int) -> None:
    with transfer_lock:
        global bytes_transferred
        bytes_transferred += n


def _current_bytes_transferred() -> int:
    with transfer_lock:
        return bytes_transferred


def _current_active_transfers() -> int:
    """Thread-safe accessor for the active transfer count.

    Required for free-threaded Python 3.14t where len() on a dict
    without holding the lock is a data race.  On CPython with GIL
    this is safe by accident, but the documented invariant requires
    lock-protected access.
    """
    with transfer_lock:
        return len(active_transfers)


def _current_banned_ips() -> int:
    """Thread-safe accessor for the banned IP count."""
    with security_lock:
        return len(banned_ips)

# ---------------------------------------------------------------------------
# Background state cleanup
# ---------------------------------------------------------------------------

def _cleanup_state() -> None:
    """Purge stale rate-limit and connection entries.

    Snapshots keys under the lock, then re-acquires to delete, so
    the lock is not held during iteration over potentially large
    data structures.
    """
    now = time.monotonic()

    # --- rate_lock group ---
    with rate_lock:
        stale_rl = [ip for ip, ts in request_log.items()
                    if not any(now - t < RATE_LIMIT_WINDOW for t in ts)]
        stale_ac = [ip for ip, v in active_connections.items() if v == 0]
    if stale_rl or stale_ac:
        with rate_lock:
            for ip in stale_rl:
                # Re-check timestamps before deleting: new requests may
                # have added entries between the snapshot and this pass.
                ts = request_log.get(ip, [])
                if not any(now - t < RATE_LIMIT_WINDOW for t in ts):
                    request_log.pop(ip, None)
            for ip in stale_ac:
                # Re-check the value before deleting: a new connection
                # may have incremented the counter between the snapshot
                # and this deletion pass.
                if active_connections.get(ip, 0) == 0:
                    active_connections.pop(ip, None)
        log.debug("Cleanup: purged %d rate-log, %d connection entries",
                  len(stale_rl), len(stale_ac))

    # --- security_lock group ---
    with security_lock:
        stale_fa = [ip for ip, v in failed_attempts.items() if v == 0]
    if stale_fa:
        with security_lock:
            for ip in stale_fa:
                failed_attempts.pop(ip, None)
        log.debug("Cleanup: purged %d zeroed failed-attempt entries",
                  len(stale_fa))


# ---------------------------------------------------------------------------
# Header-read deadline reaper
#
# Every connection gets a hard wall-clock deadline for sending its
# request line and headers.  Instead of one timer thread per connection,
# each handler registers its socket here while it parses headers and the
# background maintenance thread closes any connection whose deadline has
# elapsed.  This is the slowloris defence.
# ---------------------------------------------------------------------------

reaper_lock = threading.Lock()
_header_deadlines: dict = {}   # connection socket -> absolute monotonic deadline


def _register_header_deadline(conn, deadline: float) -> None:
    """Arm the header-read deadline for a connection."""
    with reaper_lock:
        _header_deadlines[conn] = deadline


def _deregister_header_deadline(conn) -> None:
    """Disarm the header-read deadline for a connection.

    Holding ``reaper_lock`` here is also the synchronisation barrier
    against the reaper: the reaper shuts a connection down while holding
    the same lock, so once this call returns the connection is either
    still safe to use or has been fully closed - never caught mid-close.
    """
    with reaper_lock:
        _header_deadlines.pop(conn, None)


def _reap_header_deadlines() -> None:
    """Close every connection whose header-read deadline has elapsed.

    ``shutdown(SHUT_RDWR)`` half-closes the socket without releasing the
    file descriptor: the worker thread still owns the fd and closes it
    in its normal cleanup path, so descriptor ownership stays
    unambiguous even though two threads touched the connection.  The
    teardown runs under ``reaper_lock`` so a worker deregistering the
    same connection cannot race it.
    """
    now = time.monotonic()
    with reaper_lock:
        expired = [conn for conn, deadline in _header_deadlines.items()
                   if now > deadline]
        for conn in expired:
            del _header_deadlines[conn]
            try:
                conn.shutdown(socket.SHUT_RDWR)
            except OSError:
                # Already closed or never connected - both are fine.
                log.debug("Reaper could not shut down a connection",
                          exc_info=True)
            else:
                log.debug("Header-read deadline expired; connection closed.")


def start_maintenance_thread(
    server: ThreadingHTTPServer,
    ctrl_thread: threading.Thread,
    started_at: float,
    duration: int,
) -> threading.Thread:
    """Start the single background maintenance thread.

    One thread, ticking once per second, owns every periodic task that
    does not write to the terminal:

      * closing connections whose header-read deadline has elapsed;
      * triggering graceful shutdown when the time limit is reached;
      * shutting the server down if the control-plane thread dies, so a
        daemon can never become invisible to ``pasla list`` / ``stop``;
      * purging stale rate-limit and connection bookkeeping;
      * performing the actual ``server.shutdown()`` once a shutdown has
        been requested from anywhere.

    Each step is isolated so a failure in one never stops the others.
    The status bar runs on its own separate thread, so that a blocked
    terminal write can never stall the slowloris defence.
    """
    deadline = started_at + duration
    cleanup_every = max(
        1, round(STATE_CLEANUP_INTERVAL / MAINTENANCE_TICK_INTERVAL),
    )

    def _loop() -> None:
        ticks = 0
        while not shutting_down.wait(MAINTENANCE_TICK_INTERVAL):
            ticks += 1
            _safe("header reaper", _reap_header_deadlines)

            if time.monotonic() >= deadline:
                log.info("Time limit reached.")
                shutting_down.set()
                break

            if not ctrl_thread.is_alive():
                log.error(
                    "Control plane thread died unexpectedly; shutting "
                    "down to avoid an unmanageable daemon.",
                )
                shutting_down.set()
                break

            if ticks % cleanup_every == 0:
                _safe("state cleanup", _cleanup_state)

        # Either shutting_down was set elsewhere or this loop set it.
        # Stop the server exactly once; doing so from this thread is
        # safe because serve_forever() runs on the main thread.
        _safe("server shutdown", server.shutdown)

    t = threading.Thread(target=_loop, daemon=True, name="maintenance")
    t.start()
    return t

# ---------------------------------------------------------------------------
# Range header parsing
# ---------------------------------------------------------------------------

def _normalize_request_path(raw: str) -> str | None:
    """Run the path-traversal defence pipeline.

    Returns the normalised path, or ``None`` when any step rejects the
    input.  Steps must run in this exact order - removing or
    reordering any one of them opens a traversal vector:

        1. ``unquote`` with strict UTF-8 so over-long encodings (e.g.
           the ``%c0%ae%c0%ae`` form of ``..``) raise instead of
           silently producing dot characters.
        2. Reject embedded null bytes - a classic C-string truncation
           probe used to bypass extension checks downstream.
        3. Convert backslashes to forward slashes so Windows-style
           segments do not slip past the POSIX normaliser.
        4. ``posixpath.normpath`` collapses ``./`` and ``../`` so the
           caller can compare against a fixed expected path.

    The caller is responsible for the constant-time comparison
    against the expected path via ``hmac.compare_digest`` - the four
    pre-comparison steps live here so they cannot drift apart.
    """
    try:
        decoded = unquote(raw, errors="strict")
    except UnicodeDecodeError:
        return None
    if "\x00" in decoded:
        return None
    decoded = decoded.replace("\\", "/")
    return posixpath.normpath(decoded)


def _path_segment_count(path: str) -> int:
    """Return the number of non-empty path segments (e.g. ``/a/b`` -> 2)."""
    return sum(1 for seg in path.split("/") if seg)


# Sentinel returned by parse_range_header for a syntactically valid
# bytes-range that cannot be satisfied (start beyond EOF, zero-length
# suffix).  Distinct from ``None``, which means "ignore the header and
# serve the full file" - RFC 9110 §14.2 requires unknown range units
# and malformed specs to be ignored, not rejected with 416.
RANGE_UNSATISFIABLE = object()


def parse_range_header(header: str, file_size: int):
    """Parse a ``Range`` header against ``file_size``.

    Returns:
      * ``(start, end)``        - satisfiable single bytes-range.
      * ``None``                - no header, unknown unit, multi-range,
                                  or malformed/inverted spec; the caller
                                  must ignore the header (200, full body).
      * ``RANGE_UNSATISFIABLE`` - valid bytes-range that cannot be
                                  satisfied; the caller must answer 416.
    """
    if not header:
        return None
    header = header.strip()
    if not header.startswith("bytes="):
        return None
    range_spec = header[len("bytes="):]
    if "," in range_spec:
        return None
    parts = range_spec.split("-")
    if len(parts) != 2:
        return None
    start_str, end_str = parts[0].strip(), parts[1].strip()
    try:
        if start_str == "":
            if not end_str:
                return None
            suffix = int(end_str)
            if suffix <= 0:
                # Zero suffix-length is syntactically valid but never
                # satisfiable (RFC 9110 §14.1.2).
                return RANGE_UNSATISFIABLE
            start = max(0, file_size - suffix)
            end   = file_size - 1
        else:
            start = int(start_str)
            end   = int(end_str) if end_str else file_size - 1
    except ValueError:
        return None
    if start < 0 or end < start:
        # Inverted range: invalid byte-range-spec, MUST be ignored.
        return None
    if start >= file_size:
        # Valid spec pointing beyond EOF: unsatisfiable.
        return RANGE_UNSATISFIABLE
    return start, min(end, file_size - 1)

# ---------------------------------------------------------------------------
# Graceful shutdown
# ---------------------------------------------------------------------------

def _request_shutdown() -> None:
    """Request a graceful shutdown from anywhere.

    Sets the shared flag and returns immediately; the maintenance
    thread observes the flag and performs the actual
    ``server.shutdown()``.  In-progress transfers are allowed to finish
    - only new requests are refused (with 503) once the flag is set.
    Idempotent: any caller (time limit, Ctrl+C, the control-plane
    ``stop`` command, a download-cap breach) may invoke it any number
    of times.
    """
    if not shutting_down.is_set():
        log.info("Graceful shutdown initiated - waiting for active "
                 "transfers to complete.")
    shutting_down.set()

# ---------------------------------------------------------------------------
# Request handler factory
# ---------------------------------------------------------------------------

def make_handler(
    file_path: str,
    file_name: str,
    token: str,
    max_downloads: int,
    trust_proxy: bool,
    allowed_networks: list | None = None,
    file_hash_b64: str | None = None,
    trust_header: str | None = None,
) -> type[BaseHTTPRequestHandler]:

    expected_path = f"/{token}/{file_name}"
    # A request only counts as a token-guessing attempt - and only then
    # towards the ban threshold - when its path has the same segment
    # shape as the real URL.  Browser noise such as /favicon.ico never
    # matches this shape and so can never ban a legitimate visitor.
    expected_segment_count = _path_segment_count(expected_path)

    # Capture the kernel-assigned identity of the served file at
    # handler creation time.  Verified on every request below to
    # detect symlink swaps and atomic replaces that would otherwise
    # let an attacker substitute an arbitrary file under the
    # original token.
    #
    # ``O_NOFOLLOW`` (where supported) refuses to open the path if
    # the final segment is a symlink, so a swap that replaces the
    # path with a symlink to ``/etc/passwd`` (or similar) cannot
    # complete the per-request open at all.  Per-request descriptors
    # are NOT shared with the startup handle - each request opens
    # the path fresh - to keep concurrent transfers from clashing
    # on a shared file offset.
    _initial_open_flags = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0)
    if hasattr(os, "O_BINARY"):
        _initial_open_flags |= os.O_BINARY
    _init_fd = os.open(file_path, _initial_open_flags)
    try:
        file_identity = _get_file_identity(_init_fd)
    finally:
        os.close(_init_fd)

    # ---- CLASS: SecureHandler -------------------------------------------------
    # Defined inside make_handler() so that file_path, token, max_downloads,
    # and trust_proxy are available as closure variables without requiring
    # a custom __init__ (which is incompatible with HTTPServer).
    class SecureHandler(BaseHTTPRequestHandler):
        # Security: version number removed to prevent targeted attacks
        # based on fingerprinting a specific pasla release.
        server_version = "pasla"
        sys_version    = ""

        # wfile MUST stay unbuffered.  _send_chunk() writes the response
        # body straight to the raw socket (self.connection.send) so it
        # can enforce a per-chunk stall deadline; only the response
        # headers go through wfile.  If wfile were buffered, buffered
        # header bytes could still be pending when the first body bytes
        # reach the socket, interleaving the response.  Base class
        # already defaults wbufsize to 0 - pinning it here makes the
        # hard requirement explicit and immune to a stdlib change.
        wbufsize = 0

        def log_message(self, fmt: str, *args: object) -> None:
            pass

        def log_request(self, code: int | str = "-", size: int | str = "-") -> None:
            pass

        def setup(self) -> None:
            super().setup()
            self.connection.settimeout(HEADER_READ_TIMEOUT)
            # Absolute header deadline: settimeout() above caps each
            # individual recv(), but a slowloris client can send one
            # byte every (timeout-1) seconds and hold the slot open
            # indefinitely.  Registering an absolute deadline with the
            # shared reaper caps the entire header-parsing phase.  The
            # deadline is lifted in _handle_request() once the headers
            # are fully parsed.
            _register_header_deadline(
                self.connection, time.monotonic() + HEADER_READ_TIMEOUT,
            )

        def handle(self) -> None:
            # Global connection increment is now done in
            # ThreadingHTTPServer.process_request() BEFORE the thread is
            # spawned - this is the DDoS pre-filter.

            ip = self.client_address[0]
            # The socket IP is ALWAYS tracked, even under
            # ``trust_proxy=True``: the per-proxy aggregate caps in
            # ``_validate_and_register_request`` need the connection
            # count populated regardless of whether bans/rate-limits
            # also target the XFF identity.  Per-XFF tracking happens
            # additionally inside ``_handle_request``.
            _increment_connections(ip)
            try:
                # Pre-header per-IP connection limit: reject connections
                # that exceed the configured ceiling before any header
                # bytes are read.  Without this, an attacker can open
                # unlimited slow connections from a single IP that
                # stall at header parsing, bypassing the per-IP limit
                # check in ``_validate_and_register_request`` (which
                # runs after headers are fully ingested).  Use the
                # proxy ceiling under ``--trust-proxy`` so a single
                # peer cannot saturate the slowloris window by
                # rotating XFF.
                limit = (
                    MAX_CONNECTIONS_PER_PROXY_IP
                    if trust_proxy else MAX_CONNECTIONS_PER_IP
                )
                with rate_lock:
                    over_limit = active_connections.get(ip, 0) > limit
                if over_limit:
                    # Send TCP RST instead of letting the connection
                    # idle out to the OS-level socket timeout (30 s
                    # by default).  A graceful FIN here would leave
                    # one TIME_WAIT slot per rejected connection; a
                    # peer hammering us at the per-IP ceiling rate
                    # would exhaust the kernel's ephemeral port
                    # table within minutes.  RST skips TIME_WAIT
                    # entirely; the trade-off is a "Connection reset
                    # by peer" message on the client, which is the
                    # correct signal that the request was refused.
                    try:
                        self.connection.setsockopt(
                            socket.SOL_SOCKET, socket.SO_LINGER,
                            struct.pack("ii", 1, 0),
                        )
                    except (OSError, AttributeError):
                        log.debug(
                            "SO_LINGER not settable on rejected per-IP "
                            "connection",
                            exc_info=True,
                        )
                    return
                super().handle()
            finally:
                # Lift the header-read deadline (a no-op when it was
                # already lifted once the headers were parsed) so the
                # reaper never acts on this connection after the worker
                # is finished with it.
                _deregister_header_deadline(self.connection)
                _decrement_connections(ip)

        def do_GET(self) -> None:
            self._handle_request()

        def do_HEAD(self) -> None:
            self._handle_request(head_only=True)

        def do_POST(self) -> None:    self._method_not_allowed()
        def do_PUT(self) -> None:     self._method_not_allowed()
        def do_DELETE(self) -> None:  self._method_not_allowed()
        def do_OPTIONS(self) -> None: self._method_not_allowed()
        def do_PATCH(self) -> None:   self._method_not_allowed()
        def do_TRACE(self) -> None:   self._method_not_allowed()

        def _method_not_allowed(self) -> None:
            # Unsupported methods are still subject to rate limiting and
            # the per-IP connection cap.  Without this an unauthenticated
            # peer could churn POST/PUT/... requests indefinitely without
            # ever being registered in the rate-limit log.  Bans are NOT
            # applied here - an unsupported method is not a token-guessing
            # attempt - so _record_failure is intentionally not called.
            _deregister_header_deadline(self.connection)
            ip = get_client_ip(self, trust_proxy, trust_header=trust_header)
            socket_ip = self.client_address[0]
            rejection = _validate_and_register_request(
                ip, socket_ip=socket_ip, authenticated=False,
            )
            if rejection is not None:
                code, _reason = rejection
                self._send_error(code)
                return
            self._send_error(405)

        def _handle_request(self, head_only: bool = False) -> None:
            # Headers have been successfully parsed - lift the header
            # deadline and extend the per-recv timeout for the
            # (potentially large) data-transfer phase.
            #
            # Deregistering takes reaper_lock; if the reaper happens to
            # be tearing this connection down at this very moment, that
            # lock is the barrier that makes deregister wait until the
            # teardown has fully finished.  The settimeout() call below
            # therefore never runs against a socket the reaper is
            # mid-close on.
            _deregister_header_deadline(self.connection)
            self.connection.settimeout(SOCKET_TIMEOUT)

            ip = get_client_ip(self, trust_proxy, trust_header=trust_header)
            socket_ip = self.client_address[0]

            # When ``trust_proxy=True`` and the resolved client IP is
            # distinct from the socket peer (the usual case behind a
            # reverse proxy), increment the per-XFF connection
            # counter as well.  The socket IP is already tracked in
            # ``handle()``; this layer is what drives per-XFF
            # bans/rate-limits and the matching connection cap.
            xff_tracked = trust_proxy and ip != socket_ip
            if xff_tracked:
                _increment_connections(ip)

            try:
                self._handle_request_inner(ip, head_only)
            finally:
                if xff_tracked:
                    _decrement_connections(ip)

        def _handle_request_inner(self, ip: str, head_only: bool = False) -> None:
            # Phase 1: validate the request (auth, rate-limit, path).
            error_code = self._validate_request(ip)
            if error_code is not None:
                self._send_error(error_code)
                return

            # HEAD is metadata-only: clients use it to discover the
            # file size, content type, and digest without intending
            # to download.  Counting it against ``max_downloads``
            # would let an inexpensive metadata probe exhaust the
            # cap without ever transferring a byte, so the HEAD path
            # bypasses the transfer-slot machinery entirely.
            if head_only:
                self._serve_head(ip)
                return

            self._serve_get(ip)

        def _open_served_file(self):
            """Open the served file with the same flags used at startup.

            Returns an open binary file object on success, or ``None``
            after sending a 500 response on failure.  ``O_NOFOLLOW``
            (where supported) refuses symlinks at the path; the
            per-request open also lets concurrent transfers keep
            independent file offsets.
            """
            open_flags = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0)
            if hasattr(os, "O_BINARY"):
                open_flags |= os.O_BINARY
            try:
                fd = os.open(file_path, open_flags)
                return os.fdopen(fd, "rb")
            except OSError:
                log.error(
                    "Failed to open the served file; returning 500.",
                    exc_info=True,
                )
                self._send_error(500)
                return None

        def _verify_file_identity(self, f) -> bool:
            """Confirm the open descriptor still points at the served file.

            Returns ``True`` when identity matches the snapshot
            captured at handler creation and ``False`` after sending
            a 500 response.  Detects symlink swaps and atomic
            replacements that would otherwise let an attacker
            substitute an arbitrary file under the original token.
            """
            try:
                current_identity = _get_file_identity(f.fileno())
            except OSError:
                log.error(
                    "File identity check failed; refusing to serve.",
                    exc_info=True,
                )
                self._send_error(500)
                return False
            if current_identity != file_identity:
                log.error(
                    "File identity mismatch - possible symlink swap or "
                    "TOCTOU attack. Expected %s, got %s.",
                    file_identity, current_identity,
                )
                self._send_error(500)
                return False
            return True

        def _serve_head(self, ip: str) -> None:
            """Answer a HEAD request without reserving a download slot.

            Validates the file is still the one promised at startup,
            sends the same response headers a GET would carry, and
            returns.  No body, no transfer-state bookkeeping, no
            effect on ``download_count``.
            """
            f = self._open_served_file()
            if f is None:
                return
            with f:
                if not self._verify_file_identity(f):
                    return
                file_size = os.fstat(f.fileno()).st_size
                # Synthesise a transfer ID for the response so a
                # client that follows up with a GET can echo it via
                # ``X-Transfer-ID``; it is intentionally NOT
                # registered, since HEAD does not own a slot.
                synthetic_id = secrets.token_urlsafe(TOKEN_BYTES)
                self._send_response_headers(file_size, synthetic_id)
                log.debug("HEAD served to %s (size=%d)", ip, file_size)

        def _serve_get(self, ip: str) -> None:
            """Reserve a slot, stream the file, and finalise state.

            Slot accounting is the source of truth for the
            ``max_downloads`` cap - every successful entry to this
            method consumes one slot, and the slot is released in
            the ``finally`` block regardless of how the transfer
            ends.
            """
            transfer_id     = self.headers.get("X-Transfer-ID", "").strip()
            is_new_transfer = not transfer_id

            if is_new_transfer:
                transfer_id = secrets.token_urlsafe(TOKEN_BYTES)
                _register_transfer(transfer_id)

            if not _ensure_slot_reserved(transfer_id, max_downloads):
                log.info("Download cap reached; rejecting %s", ip)
                if is_new_transfer:
                    _release_transfer(
                        transfer_id, completed=False,
                        max_downloads=max_downloads, client_ip=ip,
                    )
                # 410 Gone: the download cap is exhausted.  Note that on
                # a capped server an interrupted partial transfer parks
                # its slot as _SLOT_RESUMABLE - a fresh GET (new
                # X-Transfer-ID) cannot reuse it and also lands here.
                self._send_error(410)
                return

            completed = False
            content_length = 0
            bytes_sent = 0
            try:
                f = self._open_served_file()
                if f is None:
                    return
                with f:
                    if not self._verify_file_identity(f):
                        return

                    file_size = os.fstat(f.fileno()).st_size
                    header_result = self._send_response_headers(
                        file_size, transfer_id,
                    )
                    if header_result is None:
                        # 416 already sent by helper.
                        return
                    start, end, content_length = header_result

                    completed, bytes_sent = self._stream_file(
                        f, start, content_length, ip,
                    )

                if completed:
                    count = _current_download_count()
                    is_partial = (start, end) != (0, file_size - 1)
                    range_info = (
                        f" range={start}-{end}/{file_size}" if is_partial else ""
                    )
                    # Slot accounting only exists in capped mode; an
                    # unlimited server logs without the meaningless
                    # "slot 0/∞" prefix.
                    slot_info = (
                        f" (slot {count}/{max_downloads})"
                        if max_downloads > 0 else ""
                    )
                    log.info(
                        "Transfer complete%s - %s id=%s%s",
                        slot_info,
                        ip,
                        transfer_id,
                        range_info,
                    )
                    if max_downloads > 0 and count >= max_downloads:
                        log.info("Download cap reached. Initiating graceful shutdown.")
                        _request_shutdown()
            finally:
                # The refund guard in ``_release_transfer`` only spares
                # the slot when zero payload bytes left the server.  A
                # completed transfer reports the full content length so
                # the slot is correctly retained; a mid-stream abort
                # passes the real number of bytes that reached the
                # wire.
                effective_sent = content_length if completed else bytes_sent
                _release_transfer(
                    transfer_id, completed=completed,
                    max_downloads=max_downloads, client_ip=ip,
                    bytes_sent=effective_sent,
                )

        def _validate_request(self, ip: str) -> int | None:
            """Check shutdown state, IP validity, bans, rate limits, and path.

            Returns an HTTP error code if the request should be rejected,
            or None if validation passed.
            """
            if shutting_down.is_set():
                return 503

            try:
                client_addr = ipaddress.ip_address(ip)
            except ValueError:
                return 400

            # Socket IP - always the underlying TCP peer.  Used in
            # addition to the (possibly XFF-derived) client IP so that
            # bans cannot be evaded by rotating X-Forwarded-For while
            # holding a single TCP connection open.
            socket_ip = self.client_address[0]

            # IP allowlist check - applied before rate-limit so allowed
            # IPs are never penalised.  When --trust-proxy is active the
            # allowlist is enforced against BOTH the resolved client IP
            # (from X-Forwarded-For) AND the underlying socket peer.
            # Otherwise an attacker could spoof an allowlisted address
            # in the XFF header and bypass the gate entirely - the XFF
            # value is only as trustworthy as the proxy that wrote it,
            # so the real TCP peer must also be allowlisted.
            if allowed_networks:
                if not _ip_in_allowlist(client_addr, allowed_networks):
                    log.info("IP %s not in allowlist, rejecting.", ip)
                    return 403
                if trust_proxy and socket_ip != ip:
                    try:
                        socket_addr = ipaddress.ip_address(socket_ip)
                    except ValueError:
                        return 400
                    if not _ip_in_allowlist(socket_addr, allowed_networks):
                        log.info(
                            "Socket peer %s not in allowlist, rejecting "
                            "(client IP %s is allowlisted but the proxy "
                            "is not).",
                            socket_ip, ip,
                        )
                        return 403

            # Classify the path before the rate-limit gate so a request
            # carrying the correct token is recognised as an
            # authenticated download rather than abusive traffic.  The
            # comparison is constant-time and has no side effects.
            raw_path = self.path.split("?")[0]
            normalised = _normalize_request_path(raw_path)
            token_ok = normalised is not None and hmac.compare_digest(
                normalised.encode("utf-8"), expected_path.encode("utf-8"),
            )

            rejection = _validate_and_register_request(
                ip, socket_ip=socket_ip, authenticated=token_ok,
            )
            if rejection is not None:
                code, reason = rejection
                log.warning(
                    "Request rejected (%d, reason=%s) from %s",
                    code, reason, ip,
                )
                return code

            if token_ok:
                return None

            if normalised is None:
                # Null byte, malformed percent-encoding, or over-long
                # UTF-8 sequence - treat as a deliberate probe.
                _record_failure(ip, socket_ip=socket_ip)
                return 400

            # Token mismatch.  Only count it towards the ban threshold
            # when the path has the same segment shape as the real URL,
            # i.e. it actually looks like a token guess.  Unmatched
            # browser or scanner noise (/favicon.ico, /robots.txt, ...)
            # is answered with 404 but never bans, so a legitimate
            # recipient cannot lock themselves out by opening the link
            # in a browser.
            if _path_segment_count(normalised) == expected_segment_count:
                _record_failure(ip, socket_ip=socket_ip)

            # Log a short fingerprint instead of the raw path: an
            # attacker probing close to the real token would otherwise
            # leak partial token characters into the log file (which may
            # be readable by operators with different privilege than the
            # URL holder).
            path_fp = hashlib.sha256(raw_path.encode("utf-8", "replace")).hexdigest()[:8]
            log.info(
                "Invalid path from %s (sha256[:8]=%s, len=%d)",
                ip, path_fp, len(raw_path),
            )
            return 404

        def _send_response_headers(
            self, file_size: int, transfer_id: str,
        ) -> tuple[int, int, int] | None:
            """Parse the Range header, send status + headers.

            Returns ``(start, end, content_length)`` for the body
            phase, or ``None`` when a 416 response has already been
            emitted.  Kept as a separate method so the phase
            boundaries (range parse → status line → headers) are
            visible at a glance and so the body-streaming branch in
            ``_handle_request_inner`` reads top-to-bottom without
            inline header construction.
            """
            range_header = self.headers.get("Range", "")
            parsed_range = parse_range_header(range_header, file_size)

            if parsed_range is RANGE_UNSATISFIABLE:
                self.send_response(416)
                self.send_header("Content-Range", f"bytes */{file_size}")
                self.send_header("Content-Length", "0")
                self.end_headers()
                return None

            if parsed_range:
                start, end = parsed_range
                content_length = end - start + 1
                self.send_response(206)
                self.send_header("Content-Range", f"bytes {start}-{end}/{file_size}")
            else:
                start, end = 0, file_size - 1
                content_length = file_size
                self.send_response(200)

            self.send_header("Accept-Ranges", "bytes")
            ascii_name = file_name.encode("ascii", "ignore").decode()
            ascii_name = ascii_name.replace('"', "").replace("\n", "").replace("\r", "").replace(";", "")
            if not ascii_name:
                ascii_name = "download"
            utf8_name = quote(file_name, safe="")
            self.send_header("Content-Type", "application/octet-stream")
            self.send_header(
                "Content-Disposition",
                f'attachment; filename="{ascii_name}"; filename*=UTF-8\'\'{utf8_name}',
            )
            self.send_header("Content-Length", str(content_length))
            self.send_header("X-Transfer-ID", transfer_id)
            self.send_header("Cache-Control", "no-store, no-cache, must-revalidate")
            # HTTP/1.0 proxies do not understand Cache-Control; Pragma
            # is the only cache-suppression mechanism they recognise.
            self.send_header("Pragma", "no-cache")
            self.send_header("X-Content-Type-Options", "nosniff")
            # Prevent token leakage via browser Referer header.
            self.send_header("Referrer-Policy", "no-referrer")
            if file_hash_b64 and not parsed_range:
                self.send_header("Digest", f"sha-256={file_hash_b64}")
            self.end_headers()
            return start, end, content_length

        def _stream_file(
            self, f, start: int, content_length: int, ip: str,
        ) -> tuple[bool, int]:
            """Chunked read loop with per-chunk stall detection.

            Streams ``content_length`` bytes from file object ``f``
            starting at offset ``start``.  Returns a tuple
            ``(completed, bytes_sent)`` where ``completed`` is True
            only if the full content reached the client and
            ``bytes_sent`` is the number of bytes actually pushed to
            the wire - required by ``_release_transfer`` to decide
            whether an aborted transfer is eligible for a download
            slot refund.

            Stall detection
            ~~~~~~~~~~~~~~~
            ``SOCKET_TIMEOUT`` limits each individual ``send()`` call,
            but a slow reader that acknowledges 1 byte every
            ``SOCKET_TIMEOUT - 1`` seconds keeps every ``send()``
            under the deadline while the 256 KB chunk takes hours.
            ``TRANSFER_STALL_TIMEOUT`` enforces a wall-clock cap on
            each chunk: if the full chunk cannot be pushed to the wire
            within this window, the connection is torn down.
            """
            sent = 0
            try:
                f.seek(start)
                remaining = content_length
                buf = bytearray(CHUNK_SIZE)
                mv = memoryview(buf)
                try:
                    while remaining > 0:
                        to_read = min(remaining, CHUNK_SIZE)
                        n = f.readinto(mv[:to_read])
                        if not n:
                            break
                        # Increment the global counter BEFORE writing so
                        # callers observing the counter immediately after
                        # the client's ``recv()`` returns see the chunk
                        # accounted for.  Otherwise a fast client can
                        # finish reading before the counter update lands,
                        # producing flaky integration assertions.
                        _add_bytes_transferred(n)
                        self._send_chunk(mv[:n], ip)
                        sent += n
                        remaining -= n
                finally:
                    mv.release()
                return sent == content_length, sent
            except (ConnectionError, TimeoutError):
                # ConnectionError covers BrokenPipeError,
                # ConnectionResetError, and ConnectionAbortedError
                # (common on Windows behind proxies).  TimeoutError
                # covers socket.timeout (aliased since Python 3.3)
                # and the stall-guard deadline in _send_chunk.
                log.info("Client %s disconnected during transfer after %d/%d bytes.",
                         ip, sent, content_length)
                return False, sent

        def _send_chunk(self, data: memoryview, ip: str) -> None:
            """Push ``data`` to the wire with a per-chunk stall guard.

            Uses raw ``socket.send()`` instead of ``wfile.write()``
            (which delegates to ``sendall()``) so that we can check an
            absolute wall-clock deadline between partial sends.
            Response headers have already been flushed by
            ``end_headers()`` before ``_stream_file`` runs, so
            bypassing the buffered ``wfile`` for body data is safe.

            Raises ``TimeoutError`` if the chunk cannot be fully sent
            within ``TRANSFER_STALL_TIMEOUT`` seconds.
            """
            total = len(data)
            offset = 0
            deadline = time.monotonic() + TRANSFER_STALL_TIMEOUT
            while offset < total:
                if time.monotonic() > deadline:
                    log.warning(
                        "Transfer stalled for %s: chunk took > %ds. "
                        "Closing connection (slow-read defence).",
                        ip, TRANSFER_STALL_TIMEOUT,
                    )
                    raise TimeoutError("transfer stall: chunk deadline exceeded")
                # Keep SOCKET_TIMEOUT as the per-send() guard; the
                # deadline above catches the slow-trickle pattern that
                # SOCKET_TIMEOUT alone cannot.
                n = self.connection.send(data[offset:])
                if not n:
                    raise ConnectionError("send() returned 0")
                offset += n

        def _send_error(self, code: int) -> None:
            body = json.dumps({"error": code}).encode()
            self.send_response(code)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

    return SecureHandler

