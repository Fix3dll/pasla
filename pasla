class _BannedIPs(OrderedDict):
    """Set-like ban store with LRU eviction at MAX_BANNED_IPS.

    Preserves the original ``set`` API surface other code relies on:
    ``ip in banned_ips``, ``len(banned_ips)``, ``banned_ips.add(ip)``,
    ``banned_ips.clear()``.  Without LRU eviction, an attacker who
    rotates through ``MAX_BANNED_IPS`` disposable source IPs would
    fill the table and prevent any subsequent ban for the rest of
    the session - eviction guarantees fresh attackers can still be
    caught.
    """

    def add(self, ip: str) -> None:
        # Re-banning an existing IP is a no-op for membership but
        # refreshes its position so it survives eviction longest.
        if ip in self:
            self.move_to_end(ip)
            return
        self[ip] = None
        # Caller (``_record_failure``) already enforces MAX_BANNED_IPS
        # by checking ``len(banned_ips)`` before calling ``add()``.
        # The eviction here is a defence-in-depth fallback.
        while len(self) > MAX_BANNED_IPS:
            self.popitem(last=False)


banned_ips: _BannedIPs = _BannedIPs()
