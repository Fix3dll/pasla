# ---------------------------------------------------------------------------
# Threading HTTP server
#
# daemon_threads=False so worker threads are allowed to finish in-progress
# transfers before the process exits.
# ---------------------------------------------------------------------------

class ThreadingHTTPServer(ThreadingMixIn, HTTPServer):
    daemon_threads = False

    def process_request(self, request, client_address):
        # Security: check global connection cap BEFORE spawning a thread.
        #
        # ThreadingMixIn.process_request() creates a new OS thread (~8 MB
        # stack) per connection.  Without this gate, an attacker sending
        # 10 000 SYN packets would create 10 000 threads before handle()
        # can reject them - causing OOM or hitting the OS thread limit.
        #
        # The corresponding decrement happens in process_request_thread()
        # inside a finally block, guaranteeing counter symmetry even if
        # setup() raises before handle() is reached (e.g. the client
        # sends a TCP RST during the handshake).
        if not _try_increment_global_connections():
            log.debug("Global connection cap reached, dropping %s", client_address[0])
            # Send a TCP RST instead of a graceful FIN so the dropped
            # connection skips TIME_WAIT.  Under a SYN flood this
            # prevents kernel-level socket exhaustion (TIME_WAIT slots
            # would otherwise fill up at the configured cap rate).
            #
            # SO_LINGER with l_onoff=1, l_linger=0 makes close() send
            # RST.  On platforms where setsockopt rejects the option
            # we silently fall back to a graceful close - RST is an
            # optimisation, not a correctness requirement.
            try:
                request.setsockopt(
                    socket.SOL_SOCKET, socket.SO_LINGER,
                    struct.pack("ii", 1, 0),
                )
            except (OSError, AttributeError):
                log.debug("SO_LINGER not settable on dropped connection",
                          exc_info=True)
            try:
                request.close()
            except OSError:
                log.debug(
                    "Failed to close over-cap connection",
                    exc_info=True,
                )
            return
        try:
            super().process_request(request, client_address)
        except Exception:
            # Thread spawn (or any other inline failure inside
            # ``process_request``) raised before the worker took
            # ownership of the socket.  Roll back the counter we
            # incremented above AND close the request explicitly:
            # without the close, a sustained ``RuntimeError: can't
            # start new thread`` storm would leak one open file
            # descriptor per attempt while leaving the connection
            # half-open from the client's perspective.
            _decrement_global_connections()
            try:
                request.close()
            except OSError:
                log.debug(
                    "Failed to close request after process_request failure",
                    exc_info=True,
                )
            raise

    def process_request_thread(self, request, client_address):
        # Global connection lifecycle: the counter was incremented in
        # process_request() on the main thread.  Decrement it here,
        # wrapping the ENTIRE worker thread lifecycle, so that the
        # counter is released regardless of where the failure occurs:
        #   - setup() raises (client abort before headers)
        #   - handle() raises (unexpected exception during streaming)
        #   - finish() raises (cleanup failure)
        # Previously the decrement lived in SecureHandler.handle()'s
        # finally block, which was unreachable when setup() failed.
        try:
            super().process_request_thread(request, client_address)
        finally:
            _decrement_global_connections()

    def handle_error(self, request, client_address):
        """Suppress traceback noise from expected client-side aborts.

        ``socketserver.BaseServer`` prints a full traceback to stderr
        whenever any worker exception escapes the handler.  In
        practice the bulk of those exceptions are completely benign:

          * a browser dismisses the self-signed-cert warning, which
            tears down the TLS session before the first byte of the
            HTTP request is sent (``ssl.SSLError`` /
            ``ConnectionResetError`` from ``ssl.read``);
          * a curl client sends ``Ctrl+C`` mid-handshake
            (``BrokenPipeError`` / ``ConnectionAbortedError``);
          * a slow client times out at the OS level
            (``socket.timeout`` / ``TimeoutError``).

        These do not indicate a server-side defect, so swallow them
        with a debug-level log and let any other exception fall
        through to the default reporter.
        """
        exc = sys.exc_info()[1]
        if isinstance(
            exc,
            (ConnectionError, TimeoutError, ssl.SSLError, OSError),
        ):
            log.debug(
                "Connection from %s aborted before completion: %s",
                client_address[0] if client_address else "?",
                exc,
            )
            return
        super().handle_error(request, client_address)

# ---------------------------------------------------------------------------
# IPv6 dual-stack server
#
# On Linux, binding to '::' with IPV6_V6ONLY=0 opens a single socket that
# accepts both IPv4 and IPv6 connections.  Falls back to IPv4 if the platform
# does not support dual-stack.
# ---------------------------------------------------------------------------


def _make_server(
    port: int,
    handler: type[BaseHTTPRequestHandler],
    ip_mode: str | None = None,
) -> ThreadingHTTPServer:
    """Create an HTTP server with the appropriate address family.

    ip_mode: None = dual-stack (default), '4' = IPv4 only, '6' = IPv6 only.
    """
    # ThreadingHTTPServer.__new__() creates an uninitialised instance so that
    # address_family can be set BEFORE HTTPServer.__init__() runs - __init__
    # creates the socket using whatever address_family is set at that point.
    # Using __init__(bind_and_activate=False) alone is not enough because the
    # socket is already created with the wrong family by that time.
    srv = ThreadingHTTPServer.__new__(ThreadingHTTPServer)

    if ip_mode == "4":
        srv.address_family = socket.AF_INET
        bind_addr = ("0.0.0.0", port)
    elif ip_mode == "6":
        srv.address_family = socket.AF_INET6
        bind_addr = ("::", port)
    else:
        # Default mode: Attempt dual-stack, gracefully fallback to IPv4 if unavailable
        if socket.has_dualstack_ipv6():
            srv.address_family = socket.AF_INET6
            bind_addr = ("::", port)
        else:
            log.warning("IPv6 dual-stack not available on this platform; using IPv4 only.")
            srv.address_family = socket.AF_INET
            bind_addr = ("0.0.0.0", port)

    # Initialize HTTPServer without automatic bind to safely configure options first
    HTTPServer.__init__(srv, bind_addr, handler, bind_and_activate=False)
    
    # Explicit lifecycle management with strict resource leak prevention
    try:
        if srv.address_family == socket.AF_INET6:
            if ip_mode == "6":
                # Explicitly restrict to IPv6 only to satisfy ip_mode="6" strictly.
                srv.socket.setsockopt(socket.IPPROTO_IPV6, socket.IPV6_V6ONLY, 1)
            else:
                # Explicitly enable dual-stack.
                srv.socket.setsockopt(socket.IPPROTO_IPV6, socket.IPV6_V6ONLY, 0)
            
        srv.server_bind()
        srv.server_activate()
    except OSError as exc:
        srv.server_close()
        # In auto mode, an IPv6 bind can fail even when
        # has_dualstack_ipv6() returned True - e.g. when IPv6 is
        # disabled via sysctl (net.ipv6.conf.all.disable_ipv6=1)
        # rather than a kernel parameter.  Fall back to IPv4
        # instead of crashing.  Explicit -6 mode re-raises.
        _ipv6_unavailable = {
            getattr(errno, "EAFNOSUPPORT", None),
            getattr(errno, "EADDRNOTAVAIL", None),
        } - {None}
        if ip_mode is None and exc.errno in _ipv6_unavailable:
            log.warning(
                "IPv6 bind failed (%s); falling back to IPv4.",
                errno.errorcode.get(exc.errno, exc.errno),
            )
            return _make_server(port, handler, ip_mode="4")
        raise

    return srv

