request_log        = defaultdict(list)
active_connections = defaultdict(int)
# Transfer-slot state machine values stored in ``active_transfers``.
#   _SLOT_REGISTERED - id registered, no download slot reserved yet
#   _SLOT_IN_USE     - slot reserved, transfer currently streaming
#   _SLOT_RESUMABLE  - slot consumed by an interrupted partial transfer;
#                      a resume with the same X-Transfer-ID reuses it
#                      without counting a second download against the cap
_SLOT_REGISTERED = 0
_SLOT_IN_USE     = 1
_SLOT_RESUMABLE  = 2

active_transfers: dict[str, int] = {}    # transfer_id -> slot state
download_history: deque              = deque(maxlen=MAX_RECENT_DOWNLOADS)  # (time, ip, bytes) - ephemeral

# ---------------------------------------------------------------------------
# File identity verification (Heuristic Identity)
#
# Captures a kernel-assigned identity tuple at startup and re-checks it on
# every request. Detects symlink swaps, file replacements, and TOCTOU
# attacks between parse_and_validate() and the actual open() in the handler.
#
# SECURITY: Uses (st_dev, st_ino) - inode identifiers assigned by the
# kernel and unforgeable without root/SYSTEM privileges. On Windows
# Python < 3.12 where st_ino is always 0, falls back to the Win32
# GetFileInformationByHandle API which returns the NTFS file index.
#
# DO NOT replace with (st_size, st_mtime) - an attacker can craft a
# replacement file with identical size and modification timestamp.
# ---------------------------------------------------------------------------

def _get_file_identity(fd: int) -> tuple:
    """Return a kernel-assigned identity tuple for an open descriptor.

    Raises ``OSError`` when the running platform cannot produce a
    forgery-resistant identity.  Failing closed is deliberate: a
    degenerate value that always compared equal would silently
    disable the symlink-swap and TOCTOU defences elsewhere in the
    request path.
    """
    s = os.fstat(fd)
    if s.st_ino != 0:
        # POSIX (always), Windows Python 3.12+ (meaningful st_ino).
        return (s.st_dev, s.st_ino)

    # Windows with a zero ``st_ino`` (Python < 3.12).  Pull the NTFS
    # file index directly from the Win32 API, which is the Windows
    # equivalent of an inode and is unforgeable without elevated
    # privileges.
    if sys.platform == "win32":
        import ctypes
        import ctypes.wintypes
        import msvcrt

        class _ByHandleFileInfo(ctypes.Structure):
            _fields_ = [
                ("dwFileAttributes",     ctypes.wintypes.DWORD),
                ("ftCreationTime",       ctypes.wintypes.FILETIME),
                ("ftLastAccessTime",     ctypes.wintypes.FILETIME),
                ("ftLastWriteTime",      ctypes.wintypes.FILETIME),
                ("dwVolumeSerialNumber", ctypes.wintypes.DWORD),
                ("nFileSizeHigh",        ctypes.wintypes.DWORD),
                ("nFileSizeLow",         ctypes.wintypes.DWORD),
                ("nNumberOfLinks",       ctypes.wintypes.DWORD),
                ("nFileIndexHigh",       ctypes.wintypes.DWORD),
                ("nFileIndexLow",        ctypes.wintypes.DWORD),
            ]

        handle = msvcrt.get_osfhandle(fd)
        info = _ByHandleFileInfo()
        if ctypes.windll.kernel32.GetFileInformationByHandle(
            handle, ctypes.byref(info)
        ):
            return (
                info.dwVolumeSerialNumber,
                info.nFileIndexHigh,
                info.nFileIndexLow,
            )
        err = ctypes.windll.kernel32.GetLastError()
        raise OSError(
            err,
            "GetFileInformationByHandle failed; cannot verify file identity",
        )

    raise OSError(
        "Filesystem returned a zero inode; cannot verify file identity"
    )


