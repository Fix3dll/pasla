def _env_int(name: str, default: int) -> int:
    """Read an integer from env var PASLA_{name}, falling back to default."""
    raw = os.environ.get(f"PASLA_{name}")
    if raw is None:
        return default
    try:
        val = int(raw)
        if val < 0:
            raise ValueError("negative")
        return val
    except ValueError:
        log.warning("Invalid PASLA_%s=%r, using default %d.", name, raw, default)
        return default


