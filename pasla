def _check_tls_key_perms(key_path: str) -> None:
    """Warn when the private key file is readable by users other than
    the owner.

    POSIX-only check; Windows uses ACLs and the Python `os.stat` mode
    bits do not reflect them faithfully.  This is advisory: the
    operator may have intentionally widened the permissions (for
    example to share a key between several service users), so we log
    a warning instead of refusing to start.
    """
    if os.name == "nt":
        return
    try:
        mode = os.stat(key_path).st_mode & 0o777
    except OSError:
        return
    if mode & 0o077:
        log.warning(
            "TLS private key %s has permissive mode %o; consider "
            "tightening it to 0o600 (chmod 600 %s).",
            key_path, mode, key_path,
        )


def _get_cert_expiry(cert_path: str) -> tuple[str, int] | None:
    """Return ``(notAfter ISO date, days remaining)`` or ``None`` if
    the openssl invocation fails.

    Used purely for diagnostic banner output and a near-expiry warning;
    the TLS handshake itself is gated by the certificate's validity
    period in the standard library, so an authoritative check happens
    there too.
    """
    try:
        openssl_bin = _find_openssl()
        result = subprocess.run(
            [openssl_bin, "x509", "-in", cert_path,
             "-noout", "-enddate"],
            capture_output=True, text=True, timeout=OPENSSL_QUERY_TIMEOUT,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    line = result.stdout.strip()
    if not line.startswith("notAfter="):
        return None
    raw = line[len("notAfter="):].strip()
    # openssl prints e.g. "Aug 15 12:34:56 2026 GMT".
    # LC_TIME is forced to "C" at module startup so %b/%Z always
    # match English abbreviations regardless of system locale.
    import datetime as _dt
    try:
        not_after = _dt.datetime.strptime(raw, "%b %d %H:%M:%S %Y %Z")
    except ValueError:
        return None
    not_after = not_after.replace(tzinfo=_dt.timezone.utc)
    now = _dt.datetime.now(_dt.timezone.utc)
    delta_days = (not_after - now).days
    return not_after.date().isoformat(), delta_days


def _resolve_tls_path(path: str, label: str) -> str | None:
    """Resolve a user-supplied TLS file path, following symlinks.

    Let's Encrypt installs ``/etc/letsencrypt/live/<domain>/cert.pem``
    and friends as symlinks into ``/etc/letsencrypt/archive/<domain>/``
    that get rewritten on each renewal, so a strict no-symlink rule
    would lock pasla out of the most common CA-issued deployment.
    Following ``realpath`` once is acceptable: the operator owns both
    sides of the link, the resolved path is captured and used
    consistently for the rest of the run, and the only race window
    is the millisecond between ``realpath`` and the cert-chain load
    a few statements later in ``_setup_https``.
    """
    try:
        real = os.path.realpath(path)
    except OSError:
        log.error("TLS %s path could not be resolved: %s", label, path)
        return None
    if not os.path.isfile(real):
        log.error(
            "TLS %s file not found: %s (resolved to %s)",
            label, path, real,
        )
        return None
    return real


def _setup_https(
    server: ThreadingHTTPServer, instance_id: str,
    user_cert: str | None = None,
    user_key: str | None = None,
    key_password: str | None = None,
) -> tuple[str | None, str, str, bool]:
    """Wrap the listener in TLS.

    When ``user_cert`` and ``user_key`` are both set, pasla treats the
    operator's existing PEM files as the certificate material and
    leaves them strictly read-only on disk.  Otherwise an ephemeral
    self-signed ECDSA cert is generated under ``REGISTRY_DIR`` and
    cleaned up on shutdown.

    Returns ``(cert_dir, cert_path, key_path, ephemeral)``.  When
    ``ephemeral`` is False, ``cert_dir`` is None and the caller must
    NOT touch the user-supplied files in the cleanup path.
    """
    ephemeral = user_cert is None or user_key is None
    if ephemeral:
        cert_dir: str | None = os.path.join(
            str(REGISTRY_DIR), f"pasla_{instance_id}_tls",
        )
        os.makedirs(cert_dir, exist_ok=True)
        _write_lock_file(cert_dir)
        try:
            cert_path, key_path = _generate_ephemeral_cert(cert_dir)
        except (FileNotFoundError, subprocess.CalledProcessError):
            # Tear down the cert_dir scaffold we just created before
            # propagating; otherwise repeated --https failures (e.g.
            # openssl missing on the host) leave orphan
            # ``pasla_<id>_tls`` directories in ``REGISTRY_DIR`` that
            # only get reaped on next reboot when the OS clears its
            # temp directory.
            import shutil
            try:
                shutil.rmtree(cert_dir, ignore_errors=True)
            except OSError:
                log.debug(
                    "Failed to remove cert_dir %s after init failure",
                    cert_dir, exc_info=True,
                )
            raise
    else:
        cert_dir = None
        cert_path = user_cert
        key_path = user_key
        _check_tls_key_perms(key_path)
        expiry = _get_cert_expiry(cert_path)
        if expiry is not None:
            iso_date, days = expiry
            if days < 0:
                log.error(
                    "TLS certificate %s expired on %s (%d days ago); "
                    "refusing to start.",
                    cert_path, iso_date, -days,
                )
                server.server_close()
                sys.exit(1)
            elif days < 7:
                log.warning(
                    "TLS certificate %s expires on %s (in %d days); "
                    "consider renewing soon.",
                    cert_path, iso_date, days,
                )

    ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
    ctx.minimum_version = ssl.TLSVersion.TLSv1_2
    ctx.set_ciphers("ECDHE+AESGCM:ECDHE+CHACHA20:DHE+AESGCM:DHE+CHACHA20")
    try:
        ctx.load_cert_chain(
            certfile=cert_path, keyfile=key_path, password=key_password,
        )
    except (ssl.SSLError, OSError) as exc:
        log.error("Failed to load TLS material: %s", exc)
        if ephemeral and cert_dir:
            import shutil
            try:
                shutil.rmtree(cert_dir, ignore_errors=True)
            except OSError:
                log.debug(
                    "Failed to remove cert_dir %s after load failure",
                    cert_dir, exc_info=True,
                )
        server.server_close()
        sys.exit(1)
    server.socket = ctx.wrap_socket(server.socket, server_side=True)
    return cert_dir, cert_path, key_path, ephemeral


def _safe(label: str, fn) -> None:
    """Run a cleanup callable and swallow exceptions with a debug log.

    Used in ``cmd_serve``'s finally block so a failure in one teardown
    step does not stop subsequent steps from running.  Suppressed
    exceptions are emitted via ``log.debug(..., exc_info=True)`` so
    they remain available when running with ``--verbose`` but never
    drown out normal operational logging.
    """
    try:
        fn()
    except Exception:
        log.debug("Cleanup step %r failed", label, exc_info=True)


def cmd_serve(args: argparse.Namespace) -> None:
    _harden_registry_dir()
    file_path     = args.resolved_file
    file_name     = os.path.basename(file_path)
    duration      = args.duration_seconds
    max_downloads = args.max_downloads
    trust_proxy   = args.trust_proxy
    trust_header  = getattr(args, "trust_header", None)
    token         = secrets.token_urlsafe(TOKEN_BYTES)
    instance_id   = args.forced_instance_id or secrets.token_hex(INSTANCE_ID_BYTES)
    started_at    = time.monotonic()

    # State that the unified ``finally`` block needs visibility into.
    # Initialised up front so an early-stage failure (missing openssl
    # under --https, port collision, identity-check error inside
    # ``make_handler``) still drives every cleanup branch through
    # well-defined ``None`` checks instead of ``UnboundLocalError``.
    log_file_path: Path | None           = None
    server: ThreadingHTTPServer | None   = None
    cert_dir: str | None                 = None
    cert_path: str | None                = None
    key_path: str | None                 = None
    cert_is_ephemeral                    = True
    maintenance: threading.Thread | None = None
    status_bar: _StatusBar | None        = None
    live_handler: _LiveLogHandler | None = None
    registry_written                     = False
    clean_exit                           = False

    use_https     = getattr(args, "https", False)
    json_output   = getattr(args, "json_output", False)
    temp_tar_path: str | None = getattr(args, "temp_tar", None)
    user_tls_cert: str | None = getattr(args, "tls_cert", None)
    user_tls_key:  str | None = getattr(args, "tls_key",  None)
    # Encrypted-key support is env-only on purpose: keeping the
    # password out of argv prevents it from showing up in ``ps``,
    # shell history, or container inspect output.
    tls_key_password: str | None = os.environ.get("PASLA_TLS_KEY_PASSWORD")

    try:
        # Daemon file logging - redirect logs to a file so they are
        # not lost.  Set up first so failures further down can still
        # be captured.
        if args.daemon:
            log_file_path = REGISTRY_DIR / f"pasla_{instance_id}.log"
            REGISTRY_DIR.mkdir(parents=True, exist_ok=True)
            # Pre-create the file with mode 0o600 BEFORE handing it
            # to ``logging.FileHandler``.  Otherwise ``FileHandler``
            # opens the file under the current umask (typically
            # 0o022 → 0o644), leaving a brief window where another
            # local user can read log output that contains the
            # download URL and peer IPs.
            if os.name == "nt":
                log_file_path.touch(exist_ok=True)
                _restrict_windows_acl(str(log_file_path), is_dir=False)
            else:
                fd = os.open(
                    str(log_file_path),
                    os.O_WRONLY | os.O_CREAT | os.O_APPEND,
                    0o600,
                )
                try:
                    # Apply 0o600 explicitly in case the file
                    # pre-existed with looser permissions.
                    os.fchmod(fd, 0o600)
                finally:
                    os.close(fd)
            file_handler = logging.FileHandler(str(log_file_path), encoding="utf-8")
            file_handler.setFormatter(logging.Formatter(LOG_FORMAT, datefmt=LOG_DATEFMT))
            log.addHandler(file_handler)

        if trust_proxy:
            header_info = (
                f"  --trust-header is set to '{trust_header}'."
                if trust_header else
                "  Client IP is derived from X-Forwarded-For (rightmost)."
            )
            log.warning(
                "--trust-proxy is enabled.  All IP-based security controls "
                "(rate limiting, bans, connection caps) derive the client "
                "identity from HTTP headers.%s  If the server is directly "
                "internet-facing without a trusted proxy, an attacker can "
                "spoof headers and bypass these controls.",
                header_info,
            )

        ip_mode          = args.ip_mode
        user_port        = getattr(args, "port", None)
        server, port     = bind_server(ip_mode, port=user_port)
        allowed_networks = getattr(args, "allowed_networks", None)
        scheme           = "https" if use_https else "http"

        # SHA-256 checksum (smart default).
        file_hash_hex: str | None = None
        file_hash_b64: str | None = None
        if getattr(args, "checksum", False):
            show_progress = not args.daemon and not json_output
            file_hash_hex, file_hash_b64 = _compute_file_hash(file_path, show_progress)

        # HTTPS: load user-supplied cert/key, or generate an ephemeral
        # self-signed pair and wrap the server socket.  Failures here
        # propagate into the unified finally so the bound socket, the
        # temporary archive created for directory sharing, and the daemon
        # log file are all reaped before the process exits non-zero.
        if use_https:
            try:
                cert_dir, cert_path, key_path, cert_is_ephemeral = _setup_https(
                    server, instance_id,
                    user_cert=user_tls_cert,
                    user_key=user_tls_key,
                    key_password=tls_key_password,
                )
            except (FileNotFoundError, subprocess.CalledProcessError):
                sys.exit(1)

        try:
            server.RequestHandlerClass = make_handler(
                file_path, file_name, token, max_downloads, trust_proxy,
                allowed_networks=allowed_networks,
                file_hash_b64=file_hash_b64,
                trust_header=trust_header,
            )
        except OSError as exc:
            # Most likely the served file disappeared between
            # ``parse_and_validate`` and the handler creation, or the
            # platform refused to produce a forgery-resistant file
            # identity for the symlink-swap defence.  Either way we
            # cannot serve safely; surface a single readable line and
            # let the unified ``finally`` reap the bound socket and
            # any temporary artefacts.
            log.error("Cannot prepare request handler: %s", exc)
            sys.exit(1)
        server.timeout = SOCKET_TIMEOUT

        # In daemon mode, log key details that would otherwise be
        # invisible since the startup banner is suppressed.
        if args.daemon:
            log.info("Daemon started: id=%s file=%s port=%d",
                     instance_id, _safe_display(file_name), port)

        ips  = detect_public_ips(ip_mode)
        urls: dict[str, str] = {}
        for proto, ip in ips.items():
            urls[proto] = format_url(ip, port, token, file_name, scheme=scheme)

        # Build the status payload once; dynamic fields are updated
        # via closures over shared state.
        # Update-check result holder: written once by the background
        # update-check thread, read by get_status().  Single writer,
        # single reader, immutable value - no lock required.
        _update_state = {"available": None}

        def get_status() -> dict:
            now = time.monotonic()
            status = {
                "id":                instance_id,
                "file":              file_name,
                "port":              port,
                "remaining_seconds": max(0, int(started_at + duration - now)),
                "duration":          duration,
                "download_count":    _current_download_count(),
                "completed_downloads": _current_completed_downloads(),
                "max_downloads":     max_downloads,
                "bytes_transferred": _current_bytes_transferred(),
                # Thread-safe accessors - required for free-threaded
                # Python 3.14t where len() without the lock is a
                # data race.
                "active_transfers":  _current_active_transfers(),
                "banned_ips":        _current_banned_ips(),
                "trust_proxy":       trust_proxy,
                "https":             use_https,
                "version":           __version__,
            }
            if file_hash_hex:
                status["file_sha256"] = file_hash_hex
            if _update_state["available"]:
                status["update_available"] = _update_state["available"]
            if "ipv4" in urls:
                status["url_ipv4"] = urls["ipv4"]
            if "ipv6" in urls:
                status["url_ipv6"] = urls["ipv6"]
            with transfer_lock:
                recent = []
                for ts, dl_ip, dl_bytes in list(download_history)[-MAX_RECENT_DOWNLOADS:]:
                    ago = int(now - ts)
                    if ago < 60:
                        ago_str = f"{ago}s ago"
                    elif ago < 3600:
                        ago_str = f"{ago // 60}m ago"
                    else:
                        ago_str = f"{ago // 3600}h ago"
                    recent.append({"time": ago_str, "ip": dl_ip, "size": _fmt_bytes(dl_bytes)})
            status["recent_downloads"] = recent
            return status

        # Control plane authentication secret - stored in the
        # registry so cmd_list / cmd_stop can authenticate.
        ctrl_secret = secrets.token_urlsafe(TOKEN_BYTES)

        ctrl_port, ctrl_thread = start_control_plane(
            instance_id,
            get_status_fn=get_status,
            stop_fn=_request_shutdown,
            ctrl_secret=ctrl_secret,
        )

        # Write registry - control plane is ready at this point.
        write_registry(
            instance_id, os.getpid(), ctrl_port,
            temp_archive=temp_tar_path, ctrl_secret=ctrl_secret,
        )
        registry_written = True

        # Update check (opt-out): one background, non-blocking request.
        # Never delays serving; the result surfaces via a log warning
        # and the get_status() "update_available" field.
        if getattr(args, "update_check", True):
            def _run_update_check() -> None:
                try:
                    latest = _check_for_update()
                    if latest:
                        _update_state["available"] = latest
                        log.warning("%s", _update_notice(latest))
                except Exception:
                    log.debug("Update check thread crashed", exc_info=True)
            threading.Thread(
                target=_run_update_check, daemon=True, name="update-check",
            ).start()

        cap         = f"max {max_downloads}" if max_downloads > 0 else "unlimited"
        ipv6_status = "yes" if socket.has_dualstack_ipv6() else "no (IPv4 fallback)"
        proxy_src   = "enabled (--trust-proxy)" if trust_proxy else "disabled"

        # SIGTERM handler - ensures the finally block runs when the
        # daemon is killed externally (e.g. kill <pid>, system reboot).
        def _sigterm_handler(signum, frame):
            log.info("Received signal %d from OS.", signum)
            _request_shutdown()

        signal.signal(signal.SIGTERM, _sigterm_handler)
        # On Windows, ``Ctrl+Break`` and ``GenerateConsoleCtrlEvent``
        # raise SIGBREAK rather than SIGTERM.  Wire it to the same
        # graceful shutdown path so the daemon can be stopped from
        # the console without falling back to ``taskkill /F``,
        # which kills the process synchronously and skips the
        # cleanup path entirely (orphaning the registry file, temp
        # archive, and TLS material).
        if hasattr(signal, "SIGBREAK"):
            signal.signal(signal.SIGBREAK, _sigterm_handler)

        # --json: emit a single machine-readable JSON line and
        # suppress banner/TUI.
        if not args.daemon and json_output:
            status_snapshot = {
                "url_ipv4": urls.get("ipv4", ""),
                "url_ipv6": urls.get("ipv6", ""),
            }
            payload = _build_url_payload(instance_id, status_snapshot)
            payload["file"] = file_name
            payload["port"] = port
            if file_hash_hex:
                payload["file_sha256"] = file_hash_hex
            payload["expires_seconds"] = duration
            payload["max_downloads"] = max_downloads
            if getattr(args, "dry_run", False):
                payload["dry_run"] = True
            print(json.dumps(payload), flush=True)

        # In daemon mode or --json mode suppress banner.
        if not args.daemon and not json_output:
            # Enable VT100 processing on Win10+ so OSC 8 hyperlinks
            # render in cmd.exe and PowerShell without `colorama`.
            # No-op everywhere else.
            _enable_windows_ansi()
            port_source = "user-specified" if user_port is not None else "auto"
            if not use_https:
                tls_status = "disabled"
            elif cert_is_ephemeral:
                tls_status = "enabled (self-signed, ephemeral)"
            else:
                tls_status = "enabled (user-provided)"
            info_lines = [
                f"  ID          : {instance_id}",
                f"  File        : {_safe_display(file_name)}",
                f"  Port        : {port} ({port_source})",
                f"  Expires     : {duration // 60} minute(s)",
                f"  Cap         : {cap}",
                f"  Ban after   : {BAN_THRESHOLD} failed attempts",
                f"  Rate limit  : {RATE_LIMIT_MAX_REQUESTS} req / {RATE_LIMIT_WINDOW}s per IP",
                f"  Range       : supported (resumable)",
                f"  IPv6        : {ipv6_status}",
                f"  Trust proxy : {proxy_src}",
                f"  HTTPS       : {tls_status}",
            ]
            if file_hash_hex:
                info_lines.append(f"  SHA-256     : {file_hash_hex}")
            if allowed_networks:
                cidr_str = ", ".join(str(n) for n in allowed_networks)
                info_lines.append(f"  Allowlist   : {cidr_str}")
            if use_https and cert_path:
                fp = _get_cert_fingerprint(cert_path)
                info_lines.append(f"  Cert FP     : {fp}")
                if not cert_is_ephemeral:
                    info_lines.append(f"  Cert source : {cert_path}")
                    expiry = _get_cert_expiry(cert_path)
                    if expiry is not None:
                        iso_date, days = expiry
                        info_lines.append(
                            f"  Cert expiry : {iso_date} "
                            f"({days} days remaining)",
                        )
            rule_width = max(len(line) for line in info_lines) + 2
            rule = "─" * rule_width
            print(f"\n{rule}")
            for line in info_lines:
                print(line)
            # Soft-wrap: manually break lines that exceed terminal
            # width so every character is visible regardless of
            # terminal auto-wrap support.
            try:
                term_cols = os.get_terminal_size().columns
            except (ValueError, OSError):
                term_cols = 80

            def _soft_print(text: str) -> None:
                # Lines containing ANSI/OSC escape sequences (e.g. OSC 8
                # hyperlinks) must not be sliced - arbitrary splitting
                # would bisect the escape and corrupt the terminal.
                if "\x1b" in text:
                    print(text)
                    return
                while len(text) > term_cols:
                    print(text[:term_cols])
                    text = text[term_cols:]
                if text:
                    print(text)

            # OSC 8 hyperlinks - clickable in supported terminals.
            if "ipv4" in urls:
                _soft_print(f"  IPv4 : {_osc8_link(urls['ipv4'])}")
            if "ipv6" in urls:
                _soft_print(f"  IPv6 : {_osc8_link(urls['ipv6'])}")
            _soft_print(rule)
            print()  # blank line before status bar

        # --dry-run: validate everything, print output, then exit
        # without serving.  ``clean_exit=True`` so the unified
        # finally treats this as a normal teardown.
        if getattr(args, "dry_run", False):
            if not args.daemon and not json_output:
                print("  (dry-run mode - server not started)")
            clean_exit = True
            return

        # Live status bar (foreground only).
        if not args.daemon and not json_output:
            status_bar = _StatusBar(started_at, duration, max_downloads)

            # Replace the default console handler with a coordinated
            # one that clears the status bar before printing and
            # redraws after.
            live_handler = _LiveLogHandler(status_bar)
            live_handler.setFormatter(logging.Formatter(LOG_FORMAT, datefmt=LOG_DATEFMT))
            for h in log.handlers[:]:
                if isinstance(h, logging.StreamHandler) and not isinstance(h, logging.FileHandler):
                    log.removeHandler(h)
            log.propagate = False
            log.addHandler(live_handler)

            # SIGWINCH: redraw status bar on terminal resize (POSIX only).
            if hasattr(signal, "SIGWINCH"):
                signal.signal(signal.SIGWINCH, lambda *_: status_bar.handle_resize())

            bar_thread = threading.Thread(target=status_bar.run, daemon=True, name="status-bar")
            bar_thread.start()

        # Start the background maintenance thread last, immediately
        # before serving begins: it owns the time-limit watchdog, the
        # control-plane liveness check, the header-read reaper, periodic
        # state cleanup, and the eventual server.shutdown() call.
        maintenance = start_maintenance_thread(
            server, ctrl_thread, started_at, duration,
        )

        try:
            server.serve_forever()
            clean_exit = True
        except KeyboardInterrupt:
            log.info("Stopped manually.")
            clean_exit = True
    finally:
        # Each cleanup step is independently guarded by ``_safe`` so
        # a failure in one does not prevent subsequent steps from
        # running.  Every step also tolerates ``None`` for resources
        # that were never created when the startup sequence was cut
        # short by an early failure.
        if status_bar is not None:
            _safe("status bar stop", status_bar.stop)

        def _restore_console_logging() -> None:
            if live_handler is not None:
                log.removeHandler(live_handler)
                console_handler = logging.StreamHandler()
                console_handler.setFormatter(logging.Formatter(LOG_FORMAT, datefmt=LOG_DATEFMT))
                log.addHandler(console_handler)
        _safe("restore console logging", _restore_console_logging)

        def _stop_maintenance() -> None:
            # Make sure the maintenance thread observes the shutdown
            # flag and exits - it may not have been set yet on the
            # Ctrl+C or dry-run paths - then wait briefly for the
            # thread (which performs the final server.shutdown()) to
            # finish before the rest of the teardown runs.
            shutting_down.set()
            if maintenance is not None:
                maintenance.join(timeout=MAINTENANCE_JOIN_TIMEOUT)
        _safe("stop maintenance", _stop_maintenance)

        if server is not None:
            _safe("close server socket", server.server_close)

        def _remove_registry() -> None:
            if registry_written:
                delete_registry(instance_id)
                log.info("Registry entry removed. Goodbye.")
        _safe("delete registry", _remove_registry)

        def _close_log_file() -> None:
            # Log crash warning while the file handler is still
            # active so it reaches both the log file (daemon) and
            # console (foreground).
            if log_file_path and log_file_path.exists():
                if not clean_exit:
                    log.error("Process terminated abnormally. Log preserved: %s", log_file_path)
                for h in log.handlers[:]:
                    if isinstance(h, logging.FileHandler) and h.baseFilename == os.path.abspath(log_file_path):
                        log.removeHandler(h)
                        h.close()
                if clean_exit:
                    log_file_path.unlink(missing_ok=True)
        _safe("close log file", _close_log_file)

        # Clean up the temporary archive created for directory sharing
        # and the ephemeral TLS material.  Both go through the shared
        # cleanup helpers, so the symlink and path-confinement guards
        # that protect ``pasla list`` apply on this teardown path too.
        # This runs even when the server was never fully started, so a
        # failed --https init or a bind error never leaves artefacts
        # orphaned in the registry directory.  User-supplied cert/key
        # files are owned by the operator and never touched here - the
        # ``cert_is_ephemeral`` flag (set inside ``_setup_https``) is
        # the single source of truth on whether the TLS artefacts are
        # ours to delete.
        if temp_tar_path:
            _safe("cleanup temp archive",
                  lambda: _cleanup_temp_archive({"temp_archive": temp_tar_path}))

        if cert_dir and cert_is_ephemeral:
            _safe("cleanup TLS material", lambda: _cleanup_tls_dir(instance_id))

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main() -> None:
    global ALLOWED_ROOT
    ALLOWED_ROOT = os.path.realpath(os.getcwd())
    args = parse_and_validate()

    if args.subcommand == "list":
        cmd_list()
        return

    if args.subcommand == "stop":
        cmd_stop(args)
        return

    # Default: serve a file.
    if args.detach and not args.daemon:
        # Strip --detach from argv so the daemon does not re-detach infinitely.
        argv_rest = [a for a in sys.argv[1:] if a not in ("--detach", "-d")]
        # Also strip any leftover internal flags - should not be present,
        # but defensive.
        argv_rest = [a for a in argv_rest
                     if a not in (_DAEMON_FLAG,)
                     and not a.startswith(_INSTANCE_ID_FLAG)
                     and not a.startswith(_TEMP_TAR_FLAG)]
        # If a directory was archived, replace the original path with the tar path
        # and pass the temp tar flag to the child.
        if hasattr(args, 'temp_tar') and args.temp_tar:
            argv_rest = [args.temp_tar if a == args.file else a for a in argv_rest]
            argv_rest += [_TEMP_TAR_FLAG, args.temp_tar]
        cmd_detach(argv_rest)
        return

    cmd_serve(args)


if __name__ == "__main__":
    main()
