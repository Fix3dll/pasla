def _resolve_ip(url: str) -> str | None:
    """Attempt to resolve public IP from a single resolver URL."""
    try:
        with urllib.request.urlopen(url, timeout=IP_RESOLVE_TIMEOUT) as resp:
            candidate = resp.read().decode("utf-8").strip()
            ipaddress.ip_address(candidate)
            return candidate
    except (OSError, urllib.error.URLError, ValueError, UnicodeDecodeError):
        # OSError covers socket-level failures; URLError covers HTTP
        # protocol issues from urllib; ValueError handles bogus
        # ``ip_address`` payloads; UnicodeDecodeError handles non-UTF
        # response bodies.  Each resolver is best-effort - silent
        # failure here is normal because we fall back to the next
        # resolver or the local UDP-route probe.
        log.debug("IP resolver %s failed", url, exc_info=True)
        return None


def _detect_one(resolvers: list[str]) -> str | None:
    """Query a list of resolvers in parallel, return the first valid IP."""
    pool = ThreadPoolExecutor(max_workers=len(resolvers))
    try:
        futures = {pool.submit(_resolve_ip, url): url for url in resolvers}
        for future in as_completed(futures):
            result = future.result()
            if result is not None:
                return result
        return None
    finally:
        pool.shutdown(wait=False, cancel_futures=True)


def detect_public_ips(ip_mode: str | None = None) -> dict[str, str]:
    """Return the URLs the server should advertise, by protocol family.

    ``ip_mode``: ``None`` = detect both, ``'4'`` = IPv4 only, ``'6'`` =
    IPv6 only.

    For each requested family the function tries the public-IP
    resolvers, then falls back to the OS routing table (UDP "connect"
    trick).  When neither path produces an address, the corresponding
    loopback (``127.0.0.1`` or ``::1``) is filled in and a warning is
    logged - this keeps the banner / status payload well-formed and
    usable for local testing instead of leaving it blank or printing
    a placeholder string that no client could ever resolve.
    """
    ips: dict[str, str] = {}

    if ip_mode in (None, "4"):
        ipv4 = _detect_one(PUBLIC_IP4_RESOLVERS)
        if ipv4 is None:
            log.warning(
                "Could not determine public IPv4 via resolvers. "
                "Falling back to local routing IP."
            )
            try:
                with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as s:
                    s.settimeout(IP_RESOLVE_TIMEOUT)
                    s.connect(IP4_ROUTE_PROBE)
                    ipv4 = s.getsockname()[0]
            except OSError:
                pass
        if ipv4 is None:
            log.warning(
                "Could not determine any IPv4 address; falling back to "
                "loopback (127.0.0.1).  The advertised URL will only "
                "work for clients on the same machine."
            )
            ipv4 = "127.0.0.1"
        ips["ipv4"] = ipv4

    if ip_mode in (None, "6"):
        ipv6 = _detect_one(PUBLIC_IP6_RESOLVERS)
        if ipv6 is None:
            try:
                with socket.socket(socket.AF_INET6, socket.SOCK_DGRAM) as s:
                    s.settimeout(IP_RESOLVE_TIMEOUT)
                    s.connect(IP6_ROUTE_PROBE)
                    ipv6 = s.getsockname()[0]
            except OSError:
                pass
        if ipv6 is None:
            log.warning(
                "Could not determine any IPv6 address; falling back to "
                "loopback (::1).  The advertised URL will only work "
                "for clients on the same machine."
            )
            ipv6 = "::1"
        ips["ipv6"] = ipv6

    return ips


def format_url(ip: str, port: int, token: str, file_name: str,
               scheme: str = "http") -> str:
    try:
        addr = ipaddress.ip_address(ip)
        host = f"[{ip}]" if addr.version == 6 else ip
    except ValueError:
        host = ip
    return f"{scheme}://{host}:{port}/{token}/{quote(file_name, safe='')}"


def _build_url_payload(instance_id: str, status: dict) -> dict:
    """Build a JSON-serialisable URL payload from a status dict.

    Shared by cmd_serve (--json) and cmd_detach (--json) to avoid
    duplicating the URL extraction logic.  Each detected protocol
    family is emitted as its own field; consumers that want the
    "first available" URL pick whichever of ``url_ipv4`` or
    ``url_ipv6`` is present.
    """
    payload: dict = {"id": instance_id, "version": __version__}
    url4 = status.get("url_ipv4", "")
    url6 = status.get("url_ipv6", "")
    if url4:
        payload["url_ipv4"] = url4
    if url6:
        payload["url_ipv6"] = url6
    return payload


# ---------------------------------------------------------------------------
# Update check
#
# Notify-only: fetches a tiny VERSION file from the public repository and
# logs a notice when a newer release exists.  It never downloads or runs
# any code; automatic self-update is intentionally not implemented, so
# applying an update is always a deliberate, manual step by the operator.
# The check is opt-out via the [update] config key, throttled to one
# request per day, and every failure is silent - it must never disturb
# serving.
# ---------------------------------------------------------------------------

def _parse_version(text: object) -> tuple[int, int, int] | None:
    """Parse a ``YYYY.MINOR.MICRO`` CalVer string into an int tuple.

    Accepts arbitrary input - the fetched VERSION body and the throttle
    cache file are both untrusted - and returns ``None`` for anything
    that is not exactly three ASCII-digit components.
    """
    if not isinstance(text, str):
        return None
    parts = text.strip().split(".")
    if len(parts) != 3 or not all(p.isascii() and p.isdigit() for p in parts):
        return None
    return (int(parts[0]), int(parts[1]), int(parts[2]))


def _update_notice(latest: str) -> str:
    """Build the one-line 'a newer version is available' log message.

    The download command is depicted with this script's own resolved
    path so the user overwrites the exact file they are running.
    """
    dest = os.path.realpath(__file__)
    if os.name == "nt":
        how = f'Invoke-WebRequest -Uri "{UPDATE_DOWNLOAD_URL}" -OutFile "{dest}"'
    else:
        how = f'curl -fsSL {UPDATE_DOWNLOAD_URL} -o "{dest}"'
    return (
        f"A newer pasla version is available: {latest} "
        f"(current: {__version__}).  Update with:  {how}"
    )


def _check_for_update() -> str | None:
    """Return the latest version string if it is newer than this build.

    Best-effort and notify-only: throttled to one network request per
    ``UPDATE_CHECK_INTERVAL``, the response size is capped, parsing is
    strict, and every failure is swallowed (logged at debug level).
    Never raises - it runs on a background thread that must not disturb
    serving.
    """
    if os.environ.get("PASLA_CI"):
        return None
    cache_path = REGISTRY_DIR / "update_check.json"
    now = time.time()
    latest_str: object = None

    # Throttle: reuse a recent cached result instead of the network.
    try:
        cached = json.loads(cache_path.read_text(encoding="utf-8"))
        if (isinstance(cached, dict)
                and now - float(cached.get("checked_at", 0))
                < UPDATE_CHECK_INTERVAL):
            latest_str = cached.get("latest")
    except (OSError, ValueError, TypeError):
        latest_str = None

    if not isinstance(latest_str, str):
        try:
            with urllib.request.urlopen(
                UPDATE_VERSION_URL, timeout=IP_RESOLVE_TIMEOUT,
            ) as resp:
                body = resp.read(UPDATE_CHECK_MAX_BYTES).decode("utf-8", "strict")
        except (OSError, urllib.error.URLError, ValueError, UnicodeDecodeError):
            log.debug("Update check network request failed", exc_info=True)
            return None
        if _parse_version(body) is None:
            log.debug("Update check received an unparseable VERSION body")
            return None
        latest_str = body.strip()
        try:
            REGISTRY_DIR.mkdir(parents=True, exist_ok=True)
            cache_path.write_text(
                json.dumps({"checked_at": now, "latest": latest_str}),
                encoding="utf-8",
            )
        except OSError:
            log.debug("Update check cache write failed", exc_info=True)

    latest = _parse_version(latest_str)
    current = _parse_version(__version__)
    if latest is not None and current is not None and latest > current:
        return latest_str
    return None


# Placeholder handler for bind_server - replaced immediately after bind
# by make_handler().  Defined at module level to avoid re-creating the
# class object on every bind_server() call.
class _NullHandler(BaseHTTPRequestHandler):
    """Silent handler used only during port binding."""
    def log_message(self, *a: object) -> None:
        pass


def bind_server(
    ip_mode: str | None = None,
    port: int | None = None,
) -> tuple[ThreadingHTTPServer, int]:
    """Bind an HTTP server and return (server, port).

    Port selection strategy:
      - port=None  → random port from PORT_RANGE_START..PORT_RANGE_END with
                     PORT_BIND_MAX_RETRIES attempts, falling back to OS-assigned.
      - port=0     → OS-assigned ephemeral port (always succeeds).
      - port=N     → bind to exactly port N; raises OSError on failure.
    """
    if ip_mode == "6" and not socket.has_ipv6:
        log.error("IPv6 is not available on this system.")
        sys.exit(1)

    # User specified an exact port - single attempt, no retry.
    if port is not None:
        try:
            srv = _make_server(port, _NullHandler, ip_mode)
        except OSError as exc:
            if port == 0:
                raise  # OS-assigned should never fail; don't mask the real error
            log.error(
                "Cannot bind to port %d: %s. "
                "The port may be in use or require elevated privileges.",
                port, exc,
            )
            sys.exit(1)
        actual = port if port != 0 else srv.server_address[1]
        return srv, actual

    # Default: try random ports in the configured range.
    for attempt in range(PORT_BIND_MAX_RETRIES):
        rnd_port = secrets.randbelow(PORT_RANGE_END - PORT_RANGE_START) + PORT_RANGE_START
        try:
            srv = _make_server(rnd_port, _NullHandler, ip_mode)
            return srv, rnd_port
        except OSError:
            log.debug("Port %d in use, retrying (%d/%d).",
                      rnd_port, attempt + 1, PORT_BIND_MAX_RETRIES)

    log.warning(
        "Could not bind in range %d-%d after %d attempts; using OS-assigned port.",
        PORT_RANGE_START, PORT_RANGE_END, PORT_BIND_MAX_RETRIES,
    )
    srv = _make_server(0, _NullHandler, ip_mode)
    return srv, srv.server_address[1]

# ---------------------------------------------------------------------------
# Formatting helpers
# ---------------------------------------------------------------------------

def _fmt_bytes(n: int | float) -> str:
    v = float(n)
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if v < 1024:
            return f"{v:.1f} {unit}"
        v /= 1024
    return f"{v:.1f} PB"


def _fmt_remaining(started: float, duration: int) -> str:
    remaining = max(0, int(started + duration - time.monotonic()))
    m, s = divmod(remaining, 60)
    h, m = divmod(m, 60)
    if h:
        return f"{h}h {m}m"
    if m:
        return f"{m}m {s}s"
    return f"{s}s"

# ---------------------------------------------------------------------------
# Live status bar (foreground mode only)
#
# Updates a single line at the bottom of the terminal every second using
# carriage return (\r).  A coordinated log handler clears the bar before
# printing log messages and redraws it afterwards to prevent visual glitches.
# ---------------------------------------------------------------------------

class _StatusBar:
    """Periodically redrawn single-line status bar for foreground mode."""

    def __init__(
        self,
        started: float,
        duration: int,
        max_downloads: int,
    ) -> None:
        self._started       = started
        self._duration      = duration
        self._max_downloads = max_downloads
        self._cols          = 80
        self._running       = True
        self._lock          = threading.Lock()

    # -- Public API used by the coordinated log handler --------------------

    def clear(self) -> None:
        with self._lock:
            sys.stdout.write("\r" + " " * self._cols + "\r")
            sys.stdout.flush()

    def draw(self) -> None:
        # Snapshot the cross-thread counters BEFORE taking _lock, so the
        # bar lock is never held while transfer_lock is acquired.  This
        # matches the ordering _LiveLogHandler.emit relies on and keeps a
        # single, consistent lock order across every bar redraw path.
        # Capped mode shows slots consumed; unlimited mode shows the
        # completed-transfer count (slots never move when there is no cap).
        dl_snapshot = (
            _current_download_count() if self._max_downloads > 0
            else _current_completed_downloads()
        )
        xfer_snapshot = _current_bytes_transferred()
        with self._lock:
            self._draw_unlocked(
                dl_snapshot=dl_snapshot, xfer_snapshot=xfer_snapshot,
            )

    # -- Internal ----------------------------------------------------------

    def _draw_unlocked(
        self,
        dl_snapshot: int | None = None,
        xfer_snapshot: int | None = None,
    ) -> None:
        """Render the status bar in place.

        ``dl_snapshot`` and ``xfer_snapshot`` let the caller pre-read
        the cross-thread counters under their own lock budget (see
        ``_LiveLogHandler.emit``).  When ``None``, this method reads
        them directly via the lock-safe accessors - appropriate for
        the periodic background redraw where holding ``_lock`` while
        briefly acquiring ``transfer_lock`` is harmless.
        """
        try:
            self._cols = os.get_terminal_size().columns
        except (ValueError, OSError):
            self._cols = 80

        remaining = _fmt_remaining(self._started, self._duration)
        if dl_snapshot is not None:
            dl = dl_snapshot
        elif self._max_downloads > 0:
            dl = _current_download_count()
        else:
            dl = _current_completed_downloads()
        cap = str(self._max_downloads) if self._max_downloads > 0 else "∞"
        xfer_value = (
            xfer_snapshot if xfer_snapshot is not None
            else _current_bytes_transferred()
        )
        xfer = _fmt_bytes(xfer_value)

        bar = f"  ⏱ {remaining} │ {dl}/{cap} downloads │ {xfer} │ Ctrl+C to stop"
        if len(bar) > self._cols:
            bar = bar[: self._cols - 1] + "…"
        sys.stdout.write("\r" + bar.ljust(self._cols) + "\r")
        sys.stdout.flush()

    def run(self) -> None:
        """Background thread loop - call from a daemon thread."""
        while self._running and not shutting_down.is_set():
            self.draw()
            shutting_down.wait(STATUS_BAR_REFRESH_INTERVAL)
        self.clear()

    def stop(self) -> None:
        self._running = False

    def handle_resize(self) -> None:
        """Called from SIGWINCH handler on POSIX."""
        self.draw()


class _LiveLogHandler(logging.Handler):
    """Log handler that coordinates output with a live status bar.

    Lock-ordering invariant
    -----------------------
    ``emit`` is called from request-handling threads (any ``log.info``
    / ``log.warning`` inside the HTTP path).  It holds ``_bar._lock``
    only for the brief clear → write → redraw sequence; it must NOT
    acquire ``transfer_lock`` (or any other request-side lock) under
    that scope, otherwise a slow terminal write would back-pressure
    every other request thread that wants to update the byte
    counter.  To enforce that, the dynamic counters are snapshotted
    BEFORE entering ``_bar._lock`` and passed to ``_draw_unlocked``
    explicitly.  Request-handling code paths must never acquire
    ``_bar._lock``.
    """

    def __init__(self, bar: _StatusBar) -> None:
        super().__init__()
        self._bar = bar

    def emit(self, record: logging.LogRecord) -> None:
        try:
            msg = self.format(record)
            # Snapshot the cross-thread counters BEFORE taking the
            # bar lock.  Each accessor briefly acquires
            # ``transfer_lock``; doing it outside the bar critical
            # section guarantees we never hold both locks at once,
            # so a slow terminal cannot stall request threads that
            # are racing to update the same counters.
            dl_snapshot = (
                _current_download_count() if self._bar._max_downloads > 0
                else _current_completed_downloads()
            )
            xfer_snapshot = _current_bytes_transferred()
            with self._bar._lock:
                sys.stdout.write("\r" + " " * self._bar._cols + "\r")
                sys.stdout.flush()
                sys.stderr.write(msg + "\n")
                sys.stderr.flush()
                self._bar._draw_unlocked(
                    dl_snapshot=dl_snapshot,
                    xfer_snapshot=xfer_snapshot,
                )
        except Exception:
            self.handleError(record)

# ---------------------------------------------------------------------------
# PID lock file helpers
#
# Used to protect temporary directories (.tmp_*, _tls) from premature
# deletion by _sweep_orphan_artifacts.  The lock file contains the PID
# of the process that created the directory; the sweep skips any
# directory whose owner PID is still alive.
# ---------------------------------------------------------------------------

def _write_lock_file(dir_path: Path | str) -> None:
    """Write a ``.pasla_lock`` file with the current PID into ``dir_path``."""
    try:
        Path(dir_path, ".pasla_lock").write_text(
            str(os.getpid()), encoding="ascii",
        )
    except OSError:
        log.debug("Failed to write lock in %s", dir_path, exc_info=True)


def _is_locked_by_live_process(dir_path: Path) -> bool:
    """Return True if ``dir_path`` has a ``.pasla_lock`` whose PID is alive."""
    lock = dir_path / ".pasla_lock"
    try:
        pid = int(lock.read_text(encoding="ascii").strip())
        return pid_is_alive(pid)
    except (OSError, ValueError):
        return False

# ---------------------------------------------------------------------------
# Registry artefact cleanup helpers
# ---------------------------------------------------------------------------

def _path_within_registry(path) -> bool:
    """Return True if ``path`` resolves to a location inside REGISTRY_DIR.

    The cleanup helpers use this to refuse operating on anything outside
    the registry directory, even when a tampered registry entry or a
    planted symlink points elsewhere.  Returns False on any resolution
    error - failing closed.
    """
    try:
        real_path = os.path.normcase(os.path.realpath(path))
        real_reg  = os.path.normcase(os.path.realpath(REGISTRY_DIR))
    except (OSError, ValueError):
        return False
    return real_path.startswith(real_reg + os.sep)


def _cleanup_temp_archive(entry: dict) -> None:
    """Remove the temporary archive and its parent directory if present.

    Security: validates that the archive path is within REGISTRY_DIR
    before deleting.  Without this check, a poisoned registry JSON entry
    (created by a local attacker who pre-created the registry directory)
    could trick ``pasla list`` into deleting arbitrary files.

    Symlink defence: refuses to follow symlinks at the archive path or
    its parent directory.  ``realpath()`` would otherwise resolve a
    same-UID attacker's symlink and let registry tampering delete
    arbitrary files.  The symlink itself is unlinked (not followed).
    """
    tz = entry.get("temp_archive")
    if not tz:
        return
    # Reject symlinks at the leaf - unlink the link, do not follow it.
    if os.path.islink(tz):
        log.warning("Refusing to follow symlink at temp_archive: %s", tz)
        try:
            os.unlink(tz)
        except OSError:
            log.debug("Failed to remove symlink %s", tz, exc_info=True)
        return
    parent = os.path.dirname(tz)
    # Reject symlinks at the parent directory - same reasoning.
    if parent and os.path.islink(parent):
        log.warning("Refusing to operate on symlinked parent dir: %s", parent)
        return
    # Path confinement: refuse to delete anything outside REGISTRY_DIR.
    if not _path_within_registry(tz):
        log.warning(
            "Refusing to delete temp_archive outside registry dir: %s", tz,
        )
        return
    try:
        os.unlink(tz)
    except OSError:
        log.debug("Failed to remove temp archive %s", tz, exc_info=True)
    
    # Remove the .pasla_lock file before attempting to delete the parent
    # directory so os.rmdir does not fail with ENOTEMPTY.
    lock_file = os.path.join(parent, ".pasla_lock")
    if os.path.exists(lock_file):
        try:
            os.unlink(lock_file)
        except OSError:
            log.debug("Failed to remove lock file %s", lock_file, exc_info=True)
        
    try:
        os.rmdir(parent)  # only succeeds if empty
    except OSError:
        log.debug("Failed to remove temp archive parent dir", exc_info=True)


def _cleanup_tls_dir(instance_id: str) -> None:
    """Remove the ephemeral TLS material for ``instance_id``.

    The directory ``REGISTRY_DIR / pasla_<id>_tls`` holds the
    self-signed certificate and private key generated by
    ``--https``.  In the normal exit path ``cmd_serve`` removes it
    inside its ``finally`` block, but a hard kill (SIGKILL on POSIX,
    ``taskkill /F`` on Windows) skips that cleanup and leaves the
    private key on disk for the configured cert validity.  This
    helper is invoked by ``pasla list`` / ``pasla stop`` whenever a
    stale registry entry is observed so the next admin command also
    reaps the orphaned key material.
    """
    tls_dir = REGISTRY_DIR / f"pasla_{instance_id}_tls"
    if not tls_dir.exists():
        return
    # Refuse to follow symlinks: a same-UID attacker who can write
    # into REGISTRY_DIR could otherwise plant a symlink to an
    # arbitrary directory and make ``pasla list`` recursively delete
    # it.
    if tls_dir.is_symlink():
        log.warning("Refusing to follow symlink at TLS dir: %s", tls_dir)
        try:
            tls_dir.unlink()
        except OSError:
            log.debug("Failed to remove TLS symlink", exc_info=True)
        return
    if not _path_within_registry(tls_dir):
        log.warning("Refusing to remove TLS dir outside registry: %s", tls_dir)
        return
    import shutil
    try:
        shutil.rmtree(tls_dir, ignore_errors=False)
    except OSError:
        log.debug("Failed to remove TLS dir %s", tls_dir, exc_info=True)


def _cleanup_log_file(instance_id: str) -> None:
    """Remove the daemon log file for ``instance_id``.

    The daemon writes to ``REGISTRY_DIR / pasla_<id>.log`` while it
    runs.  A clean exit removes the file inside ``cmd_serve``'s
    ``finally`` block, but a hard kill leaves it on disk indefinitely
    - and the log records peer IPs and the configured banner,
    information operators reasonably expect to be ephemeral once the
    instance is gone.  This helper is the lazy-cleanup counterpart
    invoked from ``pasla list`` / ``pasla stop``.
    """
    log_path = REGISTRY_DIR / f"pasla_{instance_id}.log"
    if not log_path.exists():
        return
    # Refuse to follow symlinks for the same reason ``_cleanup_tls_dir``
    # does: a same-UID attacker could otherwise redirect the unlink
    # target to an arbitrary file the user can write.
    if log_path.is_symlink():
        log.warning("Refusing to follow symlinked log file: %s", log_path)
        try:
            log_path.unlink()
        except OSError:
            log.debug("Failed to remove log symlink", exc_info=True)
        return
    if not _path_within_registry(log_path):
        log.warning(
            "Refusing to remove log file outside registry: %s", log_path,
        )
        return
    try:
        log_path.unlink()
    except OSError:
        log.debug("Failed to remove log %s", log_path, exc_info=True)


def _sweep_orphan_artifacts(
    active_ids: set,
    active_tmp_dirs: set | None = None,
) -> None:
    """Remove on-disk artefacts of instances that no longer have a
    registry entry: TLS material, daemon log files, AND orphaned
    temporary archive directories.

    Called once per ``pasla list`` invocation as a belt-and-braces
    sweep against artefacts whose JSON was already gone by the time
    we reached the per-entry cleanup branch (partial filesystem
    corruption, manual intervention, or a SIGKILL that dropped the
    registry first and left the side-files behind).  Only paths
    inside REGISTRY_DIR are touched.

    PID lock protection: ``.tmp_*`` and ``_tls`` directories that
    contain a ``.pasla_lock`` file whose PID is still alive are
    skipped - the owning process is still initialising (archiving a
    directory or generating a TLS certificate) and has not yet
    written its registry entry.
    """
    if not REGISTRY_DIR.exists():
        return
    if active_tmp_dirs is None:
        active_tmp_dirs = set()
    for tls_dir in REGISTRY_DIR.glob("pasla_*_tls"):
        # Extract <id> between ``pasla_`` and ``_tls``.
        name = tls_dir.name
        inst_id = name[len("pasla_"):-len("_tls")]
        if inst_id in active_ids:
            continue
        if _is_locked_by_live_process(tls_dir):
            continue
        _cleanup_tls_dir(inst_id)
    for log_path in REGISTRY_DIR.glob("pasla_*.log"):
        # ``pasla_<id>.log`` - strip the prefix and ``.log`` suffix.
        inst_id = log_path.stem[len("pasla_"):]
        if inst_id in active_ids:
            continue
        _cleanup_log_file(inst_id)
    # Orphaned .tmp_* directories: created by _tar_directory() but
    # never registered when a SIGKILL arrives between archiving
    # and write_registry().  Safe to remove any that are not
    # referenced by a live instance's temp_archive path AND whose
    # PID lock is either absent or points to a dead process.
    import shutil
    for tmp_dir in REGISTRY_DIR.glob(".tmp_*"):
        if tmp_dir.name in active_tmp_dirs:
            continue
        if not tmp_dir.is_dir() or tmp_dir.is_symlink():
            continue
        if _is_locked_by_live_process(tmp_dir):
            continue
        if not _path_within_registry(tmp_dir):
            continue
        try:
            shutil.rmtree(tmp_dir)
        except OSError:
            log.debug("Failed to remove orphan tmp dir %s", tmp_dir,
                      exc_info=True)


def _purge_instance(entry: dict, inst_id: str) -> None:
    """Remove every on-disk artefact of a dead instance.

    Deletes the temporary archive, the ephemeral TLS material, the
    daemon log file, and finally the registry entry itself.  Used by
    ``pasla list`` and ``pasla stop`` whenever an instance is found to
    be gone.
    """
    _cleanup_temp_archive(entry)
    _cleanup_tls_dir(inst_id)
    _cleanup_log_file(inst_id)
    delete_registry(inst_id)


# ---------------------------------------------------------------------------
# Subcommand: list
# ---------------------------------------------------------------------------

def cmd_list() -> None:
    entries = read_all_registry()
    live_rows = []
    live_ids: set = set()
    active_tmp_dirs: set = set()

    for entry in entries:
        pid       = entry.get("pid", 0)
        ctrl_port = entry.get("ctrl_port", 0)
        inst_id   = entry.get("id", "?")

        # Phase 1: process liveness check.
        if not pid_is_alive(pid):
            log.debug("Stale registry entry (dead PID %d): %s", pid, inst_id)
            _purge_instance(entry, inst_id)
            continue

        # Phase 2: control plane reachability check.
        # Pass ctrl_secret from the registry for authenticated access.
        secret = entry.get("ctrl_secret", "")
        status = ctrl_status(ctrl_port, secret=secret)
        if status is None:
            log.debug("Stale registry entry (no ctrl response): %s", inst_id)
            _purge_instance(entry, inst_id)
            continue

        live_rows.append(status)
        live_ids.add(inst_id)
        # Track temp_archive parent dirs of live instances so the orphan
        # sweep does not delete them.
        tz = entry.get("temp_archive")
        if tz:
            active_tmp_dirs.add(os.path.basename(os.path.dirname(tz)))

    # Final sweep: any side artefact whose registry JSON is gone
    # (the JSON was deleted manually, or an earlier kill dropped
    # both files at once) must also be reaped here.
    _sweep_orphan_artifacts(live_ids, active_tmp_dirs)

    if not live_rows:
        print("No active pasla instances.")
        return

    _render_table(live_rows)

def _render_table(live_rows: list[dict]) -> None:
    """Render a Unicode box table of active instance status rows."""
    # File names arrive from another process via the control plane;
    # strip any control characters before they reach the terminal.
    for r in live_rows:
        r["file"] = _safe_display(r.get("file", ""))
    col_id    = max(6, max(len(r.get("id", "")) for r in live_rows))
    col_file  = max(10, max(len(r.get("file", "")) for r in live_rows))
    col_rem   = 10
    col_dl    = 10
    col_xfer  = 11   # "Transferred"
    col_last  = 9    # "Last DL"

    def row(a, b, c, d, e, f):
        return (f"│ {a:<{col_id}} │ {b:<{col_file}} │ {c:<{col_rem}} "
                f"│ {d:<{col_dl}} │ {e:<{col_xfer}} │ {f:<{col_last}} │")

    # Measure actual rendered width from a trial row - no magic numbers.
    table_width = len(row("", "", "", "", "", ""))

    # If any URL row is wider, expand col_file to compensate.
    for r in live_rows:
        for key in ("url_ipv4", "url_ipv6"):
            u = r.get(key, "")
            if u:
                label = "IPv4" if key == "url_ipv4" else "IPv6"
                prefix = "🔒 " if r.get("https") else ""
                url_row_width = len(f"{prefix}{label}: {u}") + 4
                if url_row_width > table_width:
                    col_file += url_row_width - table_width
                    table_width = url_row_width

    # Content area between outer │ borders (dynamically derived).
    content_width = table_width - 4  # subtract "│ " (left) and " │" (right)

    sep = (f"├{'─'*(col_id+2)}┼{'─'*(col_file+2)}┼{'─'*(col_rem+2)}"
           f"┼{'─'*(col_dl+2)}┼{'─'*(col_xfer+2)}┼{'─'*(col_last+2)}┤")
    div = (f"│{'─'*(col_id+2)}┼{'─'*(col_file+2)}┼{'─'*(col_rem+2)}"
           f"┼{'─'*(col_dl+2)}┼{'─'*(col_xfer+2)}┼{'─'*(col_last+2)}│")
    top = (f"┌{'─'*(col_id+2)}┬{'─'*(col_file+2)}┬{'─'*(col_rem+2)}"
           f"┬{'─'*(col_dl+2)}┬{'─'*(col_xfer+2)}┬{'─'*(col_last+2)}┐")
    bot = (f"└{'─'*(col_id+2)}┴{'─'*(col_file+2)}┴{'─'*(col_rem+2)}"
           f"┴{'─'*(col_dl+2)}┴{'─'*(col_xfer+2)}┴{'─'*(col_last+2)}┘")

    print(top)
    print(row("ID", "File", "Remaining", "Downloads", "Transferred", "Last DL"))
    print(sep)

    for idx, r in enumerate(live_rows):
        dl_cap  = r.get("max_downloads", 0)
        if dl_cap > 0:
            dl_str = f"{r.get('download_count', 0)}/{dl_cap}"
        else:
            # Unlimited mode: slots never move, show completed transfers.
            completed = r.get("completed_downloads",
                              r.get("download_count", 0))
            dl_str = f"{completed}/∞"
        rem_sec = r.get("remaining_seconds", 0)
        m, s = divmod(rem_sec, 60)
        h, m = divmod(m, 60)
        rem_str = f"{h}h {m}m" if h else (f"{m}m {s}s" if m else f"{s}s")
        xfer    = _fmt_bytes(r.get("bytes_transferred", 0))
        recent  = r.get("recent_downloads", [])
        last_dl = recent[-1]["time"] if recent else "-"
        print(row(r.get("id", "?"), r.get("file", "?"), rem_str, dl_str, xfer, last_dl))
        prefix = "🔒 " if r.get("https") else ""
        for key in ("url_ipv4", "url_ipv6"):
            u = r.get(key, "")
            if u:
                label = "IPv4" if key == "url_ipv4" else "IPv6"
                line_content = f"{prefix}{label}: {u}"
                print(f"│ {line_content:<{content_width}} │")
        if idx < len(live_rows) - 1:
            print(div)

    print(bot)


