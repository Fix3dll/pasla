def cmd_stop(args: argparse.Namespace) -> None:
    entries = read_all_registry()

    if not entries:
        print("No active pasla instances.")
        return

    targets = entries if args.stop_all else [
        e for e in entries if args.id and e.get("id", "").startswith(args.id)
    ]

    if not targets:
        print(f"No instance found matching '{args.id}'.")
        return

    for entry in targets:
        inst_id   = entry.get("id", "?")
        ctrl_port = entry.get("ctrl_port", 0)
        secret    = entry.get("ctrl_secret", "")

        if ctrl_stop(ctrl_port, secret=secret):
            print(f"Stopping instance {inst_id} - waiting for active transfers to complete.")
        else:
            print(f"Instance {inst_id} did not respond; removing stale registry entry.")
            _purge_instance(entry, inst_id)

# ---------------------------------------------------------------------------
# Detach (--detach) - cross-platform daemonisation
#
# The current process re-spawns itself with the internal --_daemon flag,
# then waits for the PID registry file to appear (written by the child once
# the control plane is ready).  The child's URL is extracted from the
# control plane and printed before the parent exits.
#
# subprocess.Popen kwargs:
#   start_new_session=True   - detaches from the controlling terminal on
#                              POSIX; equivalent to a double-fork for our
#                              purposes.
#   creationflags            - on Windows, DETACHED_PROCESS prevents the
#                              child from inheriting the parent's console.
# ---------------------------------------------------------------------------

def cmd_detach(argv_rest: list[str]) -> None:
    # Pre-generate the instance ID so the parent knows exactly which
    # registry file to wait for - eliminates the race condition when
    # multiple detach commands run simultaneously.
    instance_id = secrets.token_hex(INSTANCE_ID_BYTES)

    cmd = [
        sys.executable, os.path.abspath(__file__),
        _DAEMON_FLAG, _INSTANCE_ID_FLAG, instance_id,
    ] + argv_rest

    kwargs: dict = {
        "stdin":  subprocess.DEVNULL,
        "stdout": subprocess.DEVNULL,
        "stderr": subprocess.DEVNULL,
    }

    if sys.platform == "win32":
        kwargs["creationflags"] = (
            subprocess.DETACHED_PROCESS | subprocess.CREATE_NEW_PROCESS_GROUP
        )
    else:
        kwargs["start_new_session"] = True

    subprocess.Popen(cmd, **kwargs)

    # Wait for the daemon to write its specific registry file.
    expected_file = registry_path(instance_id)
    deadline = time.monotonic() + DETACH_READY_TIMEOUT

    while time.monotonic() < deadline:
        try:
            time.sleep(DETACH_POLL_INTERVAL)
            if expected_file.exists():
                try:
                    entry = json.loads(expected_file.read_text(encoding="utf-8"))
                    ctrl_port = entry.get("ctrl_port", 0)
                    secret    = entry.get("ctrl_secret", "")
                    status = ctrl_status(ctrl_port, secret=secret)
                    if status:
                        # --json in argv_rest means the parent wants JSON output.
                        if "--json" in argv_rest:
                            payload = _build_url_payload(instance_id, status)
                            print(json.dumps(payload), flush=True)
                        else:
                            url4 = status.get('url_ipv4', '')
                            url6 = status.get('url_ipv6', '')
                            print(f"\nPasla started in background.")
                            print(f"ID  : {instance_id}")
                            if url4:
                                print(f"IPv4: {url4}")
                            if url6:
                                print(f"IPv6: {url6}")
                            if not url4 and not url6:
                                # Should never happen in practice -
                                # detect_public_ips falls back to a
                                # placeholder string - but keep an
                                # explicit signal so an empty status
                                # is never silently masked.
                                print("URL : (no public IP detected)")
                            print(f"\nUse 'pasla list' to monitor, 'pasla stop {instance_id}' to stop.")
                        return
                except Exception:
                    log.debug("Daemon readiness check failed", exc_info=True)
        except KeyboardInterrupt:
            print("\nCancelled by user. The background process may still be running; check 'pasla list'.", file=sys.stderr)
            sys.exit(130)

    # Background process never reported ready - exit non-zero so
    # automation scripts treat this as a failure rather than silently
    # logging a warning and proceeding.
    print("Warning: background process did not become ready within the timeout.",
          file=sys.stderr)
    print("Run 'pasla list' in a moment to check.", file=sys.stderr)
    sys.exit(2)

